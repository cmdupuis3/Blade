// TEST: Struct Dependent Bound Valid
// CGPath triangle inequality as a dependent field bound: l_out's range is
// computed from the earlier fields. `..` is half-open, hence the + 1.
struct CGPath {
    l1: Int,
    l2: Int,
    l_out: Int in abs(l1 - l2) .. l1 + l2 + 1
}
let p = CGPath { l1 = 1, l2 = 2, l_out = 2 }
let v = p.l_out
// EXPECT: v = 2

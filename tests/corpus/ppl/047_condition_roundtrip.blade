// TEST: Condition Roundtrip (Lagrange disintegration)
import ppl as ppl
// The composition IS the calculus: conditioning on a finite-support value
// = dist_reweight by its Lagrange indicator polynomial; the evidences are
// dist_expect of the same coefficients; and remixing the conditionals by
// their evidences (law of total probability) recovers the prior's tower
// EXACTLY to the surviving order. Support {0, 1, 2}: indicators
// l0 = (1, -1.5, 0.5), l1 = (0, 2, -1), l2 = (0, -0.5, 0.5); each
// evidence = 1/3; conditionals are point towers (kappa2 = 0); the
// round trip returns kappa1 = 1, kappa2 = 2/3 — the prior, re-assembled
// from its own disintegration. (Degree-2 indicators spend two of the
// prior's four orders: the round trip lives at order 2.)
type TimeIdx = Idx<3>
let A: Array<Float64 like Idx<1>, TimeIdx> = [[0.0, 1.0, 2.0]]
let d = ppl.dist(A, 4)
let z0 = ppl.dist_expect(d, 1.0, -1.5, 0.5)
let z1 = ppl.dist_expect(d, 0.0, 2.0, -1.0)
let z2 = ppl.dist_expect(d, 0.0, -0.5, 0.5)
let c0 = ppl.dist_reweight(d, 1.0, -1.5, 0.5)
let c1 = ppl.dist_reweight(d, 0.0, 2.0, -1.0)
let c2 = ppl.dist_reweight(d, 0.0, -0.5, 0.5)
let c0k1 = ppl.cumulant(c0, 1)
let c1k1 = ppl.cumulant(c1, 1)
let c2k1 = ppl.cumulant(c2, 1)
let c1k2 = ppl.cumulant(c1, 2)
let m01 = ppl.dist_mix(z0, c0, z1, c1)
let rt = ppl.dist_mix(z0 + z1, m01, z2, c2)
let rt1 = ppl.cumulant(rt, 1)
let rt2 = ppl.cumulant(rt, 2)
// EXPECT: z0 = 0.333333333333333
// EXPECT: z1 = 0.333333333333333
// EXPECT: z2 = 0.333333333333333
// EXPECT: c0k1 = [0.0]
// EXPECT: c1k1 = [1.0]
// EXPECT: c2k1 = [2.0]
// EXPECT: c1k2 = [0.0]
// EXPECT: rt1 = [1.0]
// EXPECT: rt2 = [0.666666666666667]

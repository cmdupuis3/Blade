// TEST: Free Cumulants
import ppl as ppl
// The SAME moment↔cumulant machinery summed over the NON-CROSSING lattice
// (Catalan combinatorics) — the transform of free probability, computed by
// triangular recursion fk_p = μ_p − Σ_{NC π ≠ full} Π fk_B. Ranks 1..3
// coincide with classical cumulants (every partition of ≤3 elements is
// non-crossing); rank 4 is the first divergence — exactly one partition of
// [4] crosses ({{0,2},{1,3}}), so fk4 = κ4 + κ2⊗κ2 at the crossed pairing
// (verified algebraically in the prototype oracle).
type TimeIdx = Idx<3>
let B: Array<Float64 like Idx<2>, TimeIdx> = [[1.0, 2.0, 4.0], [3.0, 5.0, 4.0]]
let (f1, f2, f3, f4) = ppl.free_cumulants(B, 4)
// EXPECT: f1 = [2.33333333333, 4.0]
// EXPECT: f2 = [1.55555555556, 0.333333333333, 0.666666666667]
// EXPECT: f3 = [0.740740740741, -0.555555555556, -0.555555555556, 0.0]
// EXPECT: f4 = [-1.20987654321, -0.259259259259, -0.518518518519, -0.111111111111, -0.222222222222]

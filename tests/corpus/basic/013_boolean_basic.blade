// TEST: Boolean Basic
// Boolean literals: True/False (capitalized) and true/false (lowercase)
let a = True
let b = False
let c = true
let d = false
let e = a && c
let f = b || d
// EXPECT: a = true
// EXPECT: b = false
// EXPECT: c = true
// EXPECT: d = false
// EXPECT: e = true
// EXPECT: f = false

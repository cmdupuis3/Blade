// TEST: Recursive Nested Function
// A block-local `function` may call itself: TypeCheck pre-binds the name to
// its declared function type before checking the body (recFuncPreBindOf), and
// codegen emits the self-referential-closure idiom — an explicit
// `std::function<...>` whose `[&]` initializer forwards its own emitted name.
let result = {
    function fact(n: Int64) -> Int64 = if n <= 1 then 1 else n * fact(n - 1)
    fact(5)
}
// EXPECT: result = 120

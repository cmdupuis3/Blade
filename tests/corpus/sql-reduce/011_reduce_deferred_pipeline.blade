// TEST: Reduce Deferred Pipeline
// The fused reduction terminal: reduce() over an UNFORCED `L <@> k`
// pipeline folds the kernel over the cells without materializing the
// array — one loop, one accumulator (this exact form used to typecheck
// and then emit non-compiling C++; now it is the blessed fused fold).
// Both the inline form and the one-let-hop form (the <@> resolution rule).
let A = [1.0, 2.0, 3.0]
let B = [4.0, 5.0, 6.0]
let s1 = reduce(method_for(zip(A, B)) <@> lambda(x, y) -> x * y, (+))
let L = method_for(zip(A, B))
let f = lambda(x, y) -> x * y
let c = L <@> f
let s2 = reduce(c, (+))
// dot product: 4 + 10 + 18
// EXPECT: s1 = 32.0
// EXPECT: s2 = 32.0

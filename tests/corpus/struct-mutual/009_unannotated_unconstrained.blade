// TEST: Mutual Unannotated Values Unconstrained
// Members are transparent aliases: unannotated underlying values are NOT
// constrained (opt-in refinement views). These violate the group's
// conservation law and still run fine.
struct Particle {
    pos: Float,
    vel: Float,
    mass: Float
}
type P1 = Particle
and P2 = Particle
where P1.vel * P1.mass + P2.vel * P2.mass == 0.0
let a = Particle { pos = 0.0, vel = 5.0, mass = 1.0 }
let b = Particle { pos = 1.0, vel = 5.0, mass = 1.0 }
let s = a.vel + b.vel
// EXPECT: s = 10

// TEST: Mutual Joint Violated (aborts)
// Both particles moving the same way: momentum not conserved, guard fires.
// ABORT: Mutual constraint violation (P1)
struct Particle {
    pos: Float,
    vel: Float,
    mass: Float
}
type P1 = Particle
and P2 = Particle
where P1.vel * P1.mass + P2.vel * P2.mass == 0.0
let (a, b): (P1, P2) = (Particle { pos = 0.0, vel = 1.0, mass = 1.0 }, Particle { pos = 1.0, vel = 1.0, mass = 1.0 })

// TEST: Spectra fft2: 3x5 field takes the naive table-DFT path on both axes
// Neither axis is a power of two, so both passes fall back to the O(n^2)
// table DFT — same per-axis contract as the 1-D fft. Pins from
// spectra/OracleDump.fs (dotnet run --project spectra/BladeSpectra.fsproj).
import spectra as sp
let x: Array<Float64 like Idx<3>, Idx<5>> = [[-1.0, -0.75, -0.5, -0.25, 0.0], [0.25, 0.5, 0.75, 1.0, 1.25], [1.5, 1.75, 2.0, 2.25, 2.5]]
let X = sp.fft2(x)
// EXPECT: X = [(11.25, 0), (-1.875, 2.5807161008834503), (-1.8750000000000002, 0.60922443043669927), (-1.875, -0.60922443043669983), (-1.8750000000000002, -2.5807161008834507), (-9.3750000000000036, 5.4126587736527405), (4.4408920985006262E-16, 0), (3.6082248300317588E-16, 1.1102230246251565E-16), (3.8857805861880479E-16, 3.8857805861880479E-16), (6.6613381477509392E-16, 2.7755575615628914E-16), (-9.375, -5.4126587736527432), (2.2204460492503131E-16, 5.5511151231257827E-17), (3.3306690738754696E-16, 3.8857805861880479E-16), (-1.3877787807814457E-16, 4.4408920985006262E-16), (5.5511151231257827E-17, 9.9920072216264089E-16)]

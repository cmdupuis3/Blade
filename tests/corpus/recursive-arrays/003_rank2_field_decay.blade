// TEST: Recursive Array Rank-2 Field Decay
// ============================================================================
// A rank-2 recursive array: each step is a whole rank-1 FIELD computed from
// the previous step's field via a pseudo-native slice function (the ex-09
// ab3_fold idiom: the elementwise expression IS the function body) — no
// imperative loop, no double-buffer; the trajectory IS the array.
// u0 = [8, 4, 2, 1, 16]; step: u' = u * 0.5
// ============================================================================
type X = Idx<5>
type T = Idx<3>
function decay(u: Array<Float like X>) -> Array<Float like X> = u * 0.5

let rec traj: Array<Float like T, X> =
    match traj with
    | zero -> zero
    | zero :: s -> zero :: [8.0, 4.0, 2.0, 1.0, 16.0]
    | prefix :: n -> prefix :: decay(prefix(n - 1))
// EXPECT: traj = [8, 4, 2, 1, 16, 4, 2, 1, 0.5, 8, 2, 1, 0.5, 0.25, 4]
// Final-segment read: bind the row first (row reads flow through bindings —
// the dense row-view path), then reduce it.
let final_field = traj(2)
// EXPECT: final_field = [2, 1, 0.5, 0.25, 4]
let final_mass = reduce(final_field, (+))
// EXPECT: final_mass = 7.75

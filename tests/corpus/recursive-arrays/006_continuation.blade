// TEST: Recursive Array Continuation
// ============================================================================
// The ex-09 run_b1 -> mid-diagnostic -> run_b2 shape: a second recursive
// array seeded from the first's final slice, with a diagnostic read between
// them. x_{n+1} = x_n * 2; first leg 4 steps from 1, second leg 3 steps
// continuing from the first leg's end.
// legA: [1, 2, 4, 8]; mid = 8; legB: [16, 32, 64] (continues doubling)
// ============================================================================
type A = Idx<4>
type B = Idx<3>
let rec legA: Array<Float like A> =
    match legA with
    | zero -> zero
    | zero :: s -> zero :: 1.0
    | prefix :: n -> prefix :: prefix(n - 1) * 2.0
// EXPECT: legA = [1, 2, 4, 8]
let mid = legA(3)
// EXPECT: mid = 8.0
let rec legB: Array<Float like B> =
    match legB with
    | zero -> zero
    | zero :: s -> zero :: legA(3) * 2.0
    | prefix :: n -> prefix :: prefix(n - 1) * 2.0
// EXPECT: legB = [16, 32, 64]

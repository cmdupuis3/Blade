// TEST: Reduce Inside Inlined Fiber Kernel
// A block kernel passed to method_for(A, A) <@> k is inlined at the apply
// site by genLoopNest via exprToCpp. The fiber dot product is expressed as
// an in-kernel reduce over the paired rows — `prodsum(a, b)` is the
// pseudo-native product-sum fold (the idiom-preferred form; a hand-rolled
// zip + index reduce is the Python-bias trap). The comm guard selects the
// upper triangle. Over A = [[1,2],[3,4]]: (0,0) = 1*1+2*2 = 5;
// (0,1) = 1*3+2*4 = 11; (1,1) = 3*3+4*4 = 25.
type TimeIdx = Idx<2>
let A: Array<Float64 like Idx<2>, TimeIdx> = [[1.0, 2.0], [3.0, 4.0]]
let L = method_for(A, A)
let k = lambda(a: Array<Float64 like TimeIdx>, b: Array<Float64 like TimeIdx>) where comm(a, b) -> prodsum(a, b)
let r = L <@> k |> compute
// EXPECT: r = [5.0, 11.0, 25.0]

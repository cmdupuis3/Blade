// ---- equivariance: rotate the geometry by R = Rz(0.7) . Ry(1.1) ------------
// Rotating the edge vectors == rotating the positions; the readout is invariant,
// so the initial-weight loss must reproduce step0_loss.
function rotslot(evsrc: Array<Float like Idx<240>>, i: Int) -> Float = {
    let kk = i / 3
    let r = i - kk * 3
    rot(r * 3 + 0) * evsrc(kk * 3 + 0) + rot(r * 3 + 1) * evsrc(kk * 3 + 1) + rot(r * 3 + 2) * evsrc(kk * 3 + 2)
}
let rot_loss = {
    let rec ev_r: Array<Float like Idx<240>> =
        match ev_r with
        | zero -> zero
        | prefix :: i -> prefix :: rotslot(all_ev, i)
    loss_ev(w1_init, w2_init, w3_init, wr_init, br_init, ev_r)
}


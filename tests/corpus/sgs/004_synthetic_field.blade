// TEST: SGS Synthetic Divergence Free Field
// ============================================================================
// The synthetic-data half of the closure arc: a 3-D periodic velocity field
// built IN-LANGUAGE from four cosine modes whose amplitudes are orthogonal
// to the DISCRETE central-difference wavevector kappa_j = sin(m_j h)/h — so
// the field is divergence-free with respect to the grid operator the sgs
// arc actually differentiates with (not merely analytically; mode C below
// is NOT analytically solenoidal, but is exactly solenoidal on this grid).
//   N = 4, L = 2pi, h = pi/2. Modes (m, a, phi):
//     A: (1,0,0)  (0.0, 0.8,-0.5)  0.3
//     B: (0,1,0)  (0.7, 0.0, 0.4)  1.1
//     C: (1,3,0)  (0.6, 0.6,-0.9)  2.0     kappa_x = -kappa_y = 2/pi
//     D: (0,0,1)  (0.5,-0.6, 0.0)  0.7
// Pins are TOLERANCE verdicts (probe values vs the sgs/ oracle, divergence
// residual, and a non-solenoidal negative control): the C++ runtime's cos
// is not bit-identical to the oracle's libm, so exact EXPECTs would be
// brittle here. Downstream tests (005+) bake oracle-printed field literals
// instead and pin bit-exactly.
// ============================================================================

let pi = 3.141592653589793
let h = pi / 2.0

// Each field is a per-point element map over the flat 64-cell grid
// (t = i*16 + j*4 + k), i, j, k recovered from the linear index.
let u0 = method_for(range<Idx<64>>) <@> lambda(t) -> {
    let i = t / 16
    let j = (t / 4) % 4
    let k = t % 4
    let x = i * h
    let y = j * h
    let z = k * h
    0.7 * cos(y + 1.1) + 0.6 * cos(x + 3.0 * y + 2.0) + 0.5 * cos(z + 0.7)
} |> compute
let u1 = method_for(range<Idx<64>>) <@> lambda(t) -> {
    let i = t / 16
    let j = (t / 4) % 4
    let k = t % 4
    let x = i * h
    let y = j * h
    let z = k * h
    0.8 * cos(x + 0.3) + 0.6 * cos(x + 3.0 * y + 2.0) - 0.6 * cos(z + 0.7)
} |> compute
let u2 = method_for(range<Idx<64>>) <@> lambda(t) -> {
    let i = t / 16
    let j = (t / 4) % 4
    let k = t % 4
    let x = i * h
    let y = j * h
    let z = k * h
    0.0 - 0.5 * cos(x + 0.3) + 0.4 * cos(y + 1.1) - 0.9 * cos(x + 3.0 * y + 2.0)
} |> compute
let build_done = 0.0

// (a) probe values vs the sgs/ oracle (squared-error tolerance: libm ulps)
let mut pr = [0.0]
let probe_done = {
    let d0 = u0(0) - 0.4502502767118629
    let d1 = u1(0) - 0.05567577700150628
    let d2 = u2(0) - 0.07830235689985615
    let d3 = u0(27) - 0.5501700147163502
    let d4 = u1(27) + 0.0773683215762771
    let d5 = u2(27) + 0.8520460293826752
    let d6 = u0(54) + 0.7565781437569636
    let d7 = u1(54) - 0.9450095796280495
    let d8 = u2(54) + 0.8787752002476716
    pr(0) = d0 * d0 + d1 * d1 + d2 * d2 + d3 * d3 + d4 * d4 + d5 * d5 + d6 * d6 + d7 * d7 + d8 * d8
    0.0
}
let probes_match_oracle = if pr(0) < 0.0000000000000000000000000001 then 1.0 else 0.0
// EXPECT: probes_match_oracle = 1.0

// (b) discrete divergence: sum of div^2 over all 64 points ~ 1e-31 per point
let mut dv = [0.0, 0.0]
let div_done = {
    let s_dv0 = reduce(method_for(range<Idx<4>>) <*> method_for(range<Idx<4>>) <*> method_for(range<Idx<4>>) <@> lambda(i, j, k) -> {
        let ip = (i + 1) % 4
        let im = (i + 3) % 4
        let jp = (j + 1) % 4
        let jm = (j + 3) % 4
        let kp = (k + 1) % 4
        let km = (k + 3) % 4
        let d = (u0(ip * 16 + j * 4 + k) - u0(im * 16 + j * 4 + k)) / (2.0 * h)
              + (u1(i * 16 + jp * 4 + k) - u1(i * 16 + jm * 4 + k)) / (2.0 * h)
              + (u2(i * 16 + j * 4 + kp) - u2(i * 16 + j * 4 + km)) / (2.0 * h)
        d * d
    }, (+), 0.0)
    dv(0) = s_dv0
    0.0
}
let field_is_divergence_free = if dv(0) < 0.00000000000000000000000001 then 1.0 else 0.0
// EXPECT: field_is_divergence_free = 1.0

// (c) negative control: a mode with amplitude PARALLEL to kappa
// (v = cos(x + 0.15) e_x) is loudly non-solenoidal on the same grid
let ctrl_done = {
    let s_dv1 = reduce(method_for(range<Idx<4>>) <*> method_for(range<Idx<4>>) <*> method_for(range<Idx<4>>) <@> lambda(i, j, k) -> {
        let ip = (i + 1) % 4
        let im = (i + 3) % 4
        let d = (cos(ip * h + 0.15) - cos(im * h + 0.15)) / (2.0 * h)
        d * d
    }, (+), 0.0)
    dv(1) = s_dv1
    0.0
}
let control_is_not_divergence_free = if dv(1) > 0.01 then 1.0 else 0.0
// EXPECT: control_is_not_divergence_free = 1.0

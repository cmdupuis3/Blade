// trained w2 = slots 91..99 of the final trajectory row
let w2v = {
    let rec wtraj: Array<Float like Epochs, State> =
        match wtraj with
        | zero -> zero
        | zero :: s -> zero :: [0.03, -0.06, 0.09, -0.12, 0.15, -0.18, 0.21, -0.24, 0.27, -0.3, 0.32999999999999996, -0.36, 0.39, -0.42, 0.44999999999999996, -0.48, 0.51, -0.54, 0.57, -0.6, 0.63, -0.6599999999999999, 0.69, -0.72, 0.75, -0.78, 0.8099999999999999, -0.84, 0.87, -0.8999999999999999, 0.9299999999999999, -0.96, 0.99, -1.02, 1.05, -1.08, 1.1099999999999999, -1.14, 1.17, -1.2, 1.23, -1.26, 1.29, -1.3199999999999998, 1.3499999999999999, -1.38, 1.41, -1.44, 1.47, -1.5, 1.53, -1.56, 1.5899999999999999, -1.6199999999999999, 1.65, -1.68, 1.71, -1.74, 1.77, -1.7999999999999998, 1.8299999999999998, -1.8599999999999999, 1.89, -1.92, 1.95, -1.98, 2.01, -2.04, 2.07, -2.1, 2.13, -2.16, 2.19, -2.2199999999999998, 2.25, -2.28, 2.31, -2.34, 2.37, -2.4, 2.4299999999999997, -2.46, 2.4899999999999998, -2.52, 2.55, -2.58, 2.61, -2.6399999999999997, 2.67, -2.6999999999999997, 2.73, 0.1, -0.2, 0.30000000000000004, -0.4, 0.5, -0.6000000000000001, 0.7000000000000001, -0.8, 0.9, 0.0]
        | prefix :: n -> prefix :: sgd_step(prefix(n - 1))
    let wf = wtraj(6)
    [wf(91), wf(92), wf(93), wf(94), wf(95), wf(96), wf(97), wf(98), wf(99)]
}
// EXPECT: w2v = [0.5535435316984045, -0.4971397950778106, 0.7806307178612995, 0.5052548994721346, -0.06241325352169922, 0.3314147534425853, -0.23252413628286503, -0.21728930831050014, -0.058772505564877967]

// trained w1 = slots 0..90 of the final trajectory row
let w1v = {
    let rec wtraj: Array<Float like Epochs, State> =
        match wtraj with
        | zero -> zero
        | zero :: s -> zero :: [0.03, -0.06, 0.09, -0.12, 0.15, -0.18, 0.21, -0.24, 0.27, -0.3, 0.32999999999999996, -0.36, 0.39, -0.42, 0.44999999999999996, -0.48, 0.51, -0.54, 0.57, -0.6, 0.63, -0.6599999999999999, 0.69, -0.72, 0.75, -0.78, 0.8099999999999999, -0.84, 0.87, -0.8999999999999999, 0.9299999999999999, -0.96, 0.99, -1.02, 1.05, -1.08, 1.1099999999999999, -1.14, 1.17, -1.2, 1.23, -1.26, 1.29, -1.3199999999999998, 1.3499999999999999, -1.38, 1.41, -1.44, 1.47, -1.5, 1.53, -1.56, 1.5899999999999999, -1.6199999999999999, 1.65, -1.68, 1.71, -1.74, 1.77, -1.7999999999999998, 1.8299999999999998, -1.8599999999999999, 1.89, -1.92, 1.95, -1.98, 2.01, -2.04, 2.07, -2.1, 2.13, -2.16, 2.19, -2.2199999999999998, 2.25, -2.28, 2.31, -2.34, 2.37, -2.4, 2.4299999999999997, -2.46, 2.4899999999999998, -2.52, 2.55, -2.58, 2.61, -2.6399999999999997, 2.67, -2.6999999999999997, 2.73, 0.1, -0.2, 0.30000000000000004, -0.4, 0.5, -0.6000000000000001, 0.7000000000000001, -0.8, 0.9, 0.0]
        | prefix :: n -> prefix :: sgd_step(prefix(n - 1))
    let wf = wtraj(6)
    [wf(0), wf(1), wf(2), wf(3), wf(4), wf(5), wf(6), wf(7), wf(8), wf(9), wf(10), wf(11), wf(12), wf(13), wf(14), wf(15), wf(16), wf(17), wf(18), wf(19), wf(20), wf(21), wf(22), wf(23), wf(24), wf(25), wf(26), wf(27), wf(28), wf(29), wf(30), wf(31), wf(32), wf(33), wf(34), wf(35), wf(36), wf(37), wf(38), wf(39), wf(40), wf(41), wf(42), wf(43), wf(44), wf(45), wf(46), wf(47), wf(48), wf(49), wf(50), wf(51), wf(52), wf(53), wf(54), wf(55), wf(56), wf(57), wf(58), wf(59), wf(60), wf(61), wf(62), wf(63), wf(64), wf(65), wf(66), wf(67), wf(68), wf(69), wf(70), wf(71), wf(72), wf(73), wf(74), wf(75), wf(76), wf(77), wf(78), wf(79), wf(80), wf(81), wf(82), wf(83), wf(84), wf(85), wf(86), wf(87), wf(88), wf(89), wf(90)]
}

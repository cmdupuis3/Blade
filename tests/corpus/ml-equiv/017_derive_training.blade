// TEST: ML Equiv Derive Training
import ml as ml
import ad as ad
// ============================================================================
// The vision end-to-end: a model built ENTIRELY from compiler-derived
// layers inside a certified function (derive_linear -> norms readout),
// trained with grad() — the weight buffer is a plain array grad() sees
// like any other. Loss trajectory + final weights pinned to the ml/ F#
// oracle (dump-oracle, derive training section: vjpHomLinear/vjpNorms SGD).
//
// SGD is expressed as a RECURSIVE ARRAY over epochs (no imperative for-in):
// each state row stacks the 4 weights with the loss evaluated at that step,
// [w0, w1, w2, w3, loss]. sgd_step is a pure function — it allocates its own
// zeroed grad buffer, runs ad.grad(loss), and returns the descended weights
// with the loss it just measured. The loss trace is the loss column of the
// trajectory; the final weights are its last row. The loss fold itself is an
// additive `reduce` (grad differentiates it exactly).
// ============================================================================
let static SIN = [(0, 0, 2), (1, 1, 1)]
let static SOUT = [(0, 0, 1), (1, 1, 2)]
let static WD = ml.hom_dim(SIN, SOUT)

let xg = [0.5, -1.2, 0.8, 0.3, -0.6]
let tgt = [1.0, 0.5, 0.25]

function model(w: Array<Float like Idx<WD>>, x: Array<Float like IrrepsIdx<SIN>>) where ml.equiv(O3) -> Array<Float like Idx<3>> = {
    let h = ml.derive_linear(SIN, SOUT, w, x)
    ml.norms(SOUT, h)
}

function loss(w: Array<Float like Idx<WD>>) -> Float = {
    let o = model(w, xg)
    reduce([(o(0) - tgt(0)) * (o(0) - tgt(0)), (o(1) - tgt(1)) * (o(1) - tgt(1)), (o(2) - tgt(2)) * (o(2) - tgt(2))], (+))
}

// one SGD step over the stacked [weights..., loss] state (lr 0.1)
type Epochs = Idx<7>
type State = Idx<5>
function sgd_step(s: Array<Float like State>) -> Array<Float like State> = {
    let w = [s(0), s(1), s(2), s(3)]
    let mut dw = [0.0, 0.0, 0.0, 0.0]
    let lv = ad.grad(loss)(w, dw)
    let wn = w - 0.1 * dw
    [wn(0), wn(1), wn(2), wn(3), lv]
}

// loss trace = the loss column of the trajectory rows 1..6 (each carries the
// loss at the weights that entered that step); trajectory is block-local.
let losses = {
    let rec wtraj: Array<Float like Epochs, State> =
        match wtraj with
        | zero -> zero
        | zero :: s -> zero :: [0.4, -0.3, 0.2, 0.1, 0.0]
        | prefix :: n -> prefix :: sgd_step(prefix(n - 1))
    let r1 = wtraj(1)
    let r2 = wtraj(2)
    let r3 = wtraj(3)
    let r4 = wtraj(4)
    let r5 = wtraj(5)
    let r6 = wtraj(6)
    [r1(4), r2(4), r3(4), r4(4), r5(4), r6(4)]
}
// EXPECT: losses = [0.29959233727723616, 0.1496608964611247, 0.07681945507354075, 0.04053397577270731, 0.021963908390851307, 0.012194035471703144]

// final weights = the weight slots of the last trajectory row
let wv = {
    let rec wtraj: Array<Float like Epochs, State> =
        match wtraj with
        | zero -> zero
        | zero :: s -> zero :: [0.4, -0.3, 0.2, 0.1, 0.0]
        | prefix :: n -> prefix :: sgd_step(prefix(n - 1))
    let wf = wtraj(6)
    [wf(0), wf(1), wf(2), wf(3)]
}
// EXPECT: wv = [0.5192207102889806, -0.5861297046935535, 0.4151294736025543, 0.20756473680127716]

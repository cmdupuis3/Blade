// TEST: Fallback Compound Trailing Blocks
// Partial-depth allocation ("checked per curry level", formalism 2.6): the
// compound covers only the LEADING dim; allocation granularity is a whole
// trailing block. Absent rows fall back as complete rows — including row 1,
// whose stored values in A are all zero and are simply never consulted.
type RIdx = Idx<3>
type CIdx = Idx<2>
let A: Array<Float64 like RIdx, CIdx> = [[1.0, 2.0], [0.0, 0.0], [5.0, 6.0]]
let keys: Array<Float64 like RIdx> = [1.0, 0.0, 1.0]
let m = mask(keys, lambda(k) -> k > 0.5)
let S = compound(A, m)
let D: Array<Float64 like RIdx, CIdx> = [[9.0, 9.0], [9.0, 9.0], [9.0, 9.0]]
let C = S <|:> D |> compute
// rows 0 and 2 present (their blocks read from S); row 1 absent (block from D)
// EXPECT: C = [1.0, 2.0, 9.0, 9.0, 5.0, 6.0]

// TEST: Mut Array Copy Semantics
// Regression probe for the mut-aliasing bug: a block-level `let mut a = Z`
// where Z is a COMPUTED array used to bind the Array wrapper by value —
// sharing Z's data pointer — so mutations through `a` silently corrupted Z
// (Z printed [0,1,2,3,4,5] here pre-fix). Assignable bindings initialized
// from an existing dense array now DEEP-COPY the storage (fresh allocate<>
// + pool copy; interpreter mirrors with a store copy). This also enables
// the "computed zeros buffer" pattern: a large mut scratch buffer built by
// compute instead of an N-zero literal. The mutations are element-wise
// assignments through the copy (the aliasing bug is exposed by writing
// THROUGH the binding, not by rebuilding it — a former would replace the
// pointer and never touch Z).
let Z = method_for(range<Idx<6>>) <@> lambda(i) -> 0.0 |> compute
let T = {
    let mut a = Z
    a(0) = 0.0
    a(1) = 1.0
    a(2) = 2.0
    a(3) = 3.0
    a(4) = 4.0
    a(5) = 5.0
    a
}
// Plain `let` is assignable too (only `static` is read-only), so the same
// copy semantics protect the non-mut spelling.
let S = {
    let b = Z
    b(0) = 10.0
    b(1) = 11.0
    b(2) = 12.0
    b(3) = 13.0
    b(4) = 14.0
    b(5) = 15.0
    b
}
// EXPECT: Z = [0, 0, 0, 0, 0, 0]
// EXPECT: T = [0, 1, 2, 3, 4, 5]
// EXPECT: S = [10, 11, 12, 13, 14, 15]

// TEST: IrrepsIdx Inline Literal
// ============================================================================
// The round-trippable surface form: the spec written INLINE in the angle
// brackets, IrrepsIdx<[(0, 0, 1), (1, 1, 1)]> — the same shape diagnostics
// render. Pins the tuple extension of the simple-expression grammar
// (parenthesized comma lists inside index-type arguments were previously a
// parse error). total_dim = 1 + 3 = 4. Note the v1 limitation: call syntax
// (IrrepsIdx<sh_spec(2)>) is NOT part of the simple-expression grammar —
// bind a `let static` first.
// ============================================================================
let x: Array<Float like IrrepsIdx<[(0, 0, 1), (1, 1, 1)]>> = [1.5, 2.5, 3.5, 4.5]
// EXPECT: x = [1.5, 2.5, 3.5, 4.5]
let v = x(2)
// EXPECT: v = 3.5

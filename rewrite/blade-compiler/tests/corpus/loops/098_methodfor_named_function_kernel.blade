// TEST: method_for with a named top-level function as its kernel
// A bare `function` reference is eta-expanded to lambda(m) -> shift(m),
// so it rides the ordinary lambda-kernel path. Regression for the
// "requires method_for ... but got TExprMethodFor" red-herring diagnostic.
function shift(m: Int64) -> Float64 = if m < 2 then 1.0 * m else 1.0 * m - 4.0
let s = method_for(range<Idx<4>>) <@> shift |> compute
// EXPECT: s = [0, 1, -2, -1]

// TEST: Bind Chained
let A = [1.0, 2.0, 3.0]
let c1 = method_for(A) <@> lambda(x) -> x + 1.0
let k1 = lambda(arr) -> method_for(arr) <@> lambda(y) -> y * 2.0
let k2 = lambda(arr) -> method_for(arr) <@> lambda(z) -> z - 1.0
let result = (c1 >>= k1 >>= k2) |> compute
// EXPECT: result = [3.0, 5.0, 7.0]

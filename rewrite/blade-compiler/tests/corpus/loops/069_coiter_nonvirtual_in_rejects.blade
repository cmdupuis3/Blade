// TEST: Coiter Non-Virtual In Clause (rejects)
// The `in` clause of a co-iteration `for` supplies the shared iteration
// index and must be a VIRTUAL array (range/reverse/blocked). A zip of
// stored arrays is not one — the checker rejects it and steers to the
// method_for(zip(...)) idiom (previously this silently mis-typed).
type TimeIdx = Idx<3>
let X: Array<Float64 like TimeIdx> = [1.0, 2.0, 4.0]
let bad = for (X, X) in zip(X, X) <@> lambda(a, b) -> a * b |> compute

// TEST: If-Bodied Kernel Read Imperatively
// Regression probe for the deferred-force hole on if-bodied kernels. A
// module-level `let A = method_for(...) <@> lambda(m) -> if c then a else b
// |> compute` stays a DEFERRED computation: parseIf parses the else branch at
// full precedence and swallows the trailing `|> compute` (the 2026-07-13
// gotcha, `else (b |> compute)` = identity on the scalar), so `compute` never
// applies to the method_for and A is never materialized. Reading A(i) from an
// imperative `{ for .. }` block then emitted `acc = acc + A[i]` referencing a
// symbol that was never declared -> g++ "'A' was not declared in this scope".
// Non-if kernels materialized fine for the same read because their body's
// `|> compute` escapes the lambda (parseApply precedence). The fix forces any
// deferred producer read POSITIONALLY (IRIndex/IRExtent base) before the
// reading binding is emitted -- collectDeferredPositionalReads +
// forceDeferredPositionalReads in CodeGen.fs, hooked into the block /
// for-range / scalar-expr binding paths.

// 1-D: reduced imperatively inside a block (the core repro). A = [1,1,2,2].
let A = method_for(range<Idx<4>>) <@> lambda(m) -> if m < 2 then 1.0 else 2.0 |> compute

let s = {
    let mut acc = 0.0
    for m in 0..4 {
        acc = acc + A(m)
    }
    acc
}

// 2-D if-bodied kernel, read from a nested-loop block. B(i,j)=i+j for i<j else 0.
let kk = method_for(range<Idx<3>>) <@> lambda(i) -> i * 1.0 |> compute
let B = method_for(range<Idx<3>, Idx<3>>) <@> lambda(i, j) -> if i < j then kk(i) + kk(j) else 0.0 |> compute

let sumB = {
    let mut acc = 0.0
    for i in 0..3 {
        for j in 0..3 {
            acc = acc + B(i, j)
        }
    }
    acc
}

// Scalar compound read (nested in a binop, no block): C = [10,10,20,20].
let C = method_for(range<Idx<4>>) <@> lambda(m) -> if m < 2 then 10.0 else 20.0 |> compute
let two = C(0) + C(3)

// EXPECT: kk = [0, 1, 2]
// EXPECT: s = 6
// EXPECT: sumB = 6
// EXPECT: two = 30

// TEST: Reduce Fused Pool
// The moment-pool shape in pure combinator algebra: rows of a rank-2
// array, one shared co-iteration loop object, one product kernel per
// row-multiset, <&!>-chained, folded by the reduction terminal — ONE
// pass over the sample axis filling every accumulator (the single-pass
// sufficient-statistic sweep the PPL formers elaborate to).
// Data = the ppl/010 oracle set: vars [1,2,4] and [3,5,4], N=3.
let A: Array<Float64 like Idx<2>, Idx<3>> = [[1.0, 2.0, 4.0], [3.0, 5.0, 4.0]]
let r0 = A(0)
let r1 = A(1)
let L = method_for(zip(r0, r1))
let k0 = lambda(x0, x1) -> x0
let k1 = lambda(x0, x1) -> x1
let k00 = lambda(x0, x1) -> x0 * x0
let k01 = lambda(x0, x1) -> x0 * x1
let k11 = lambda(x0, x1) -> x1 * x1
let (p0, p1, p00, p01, p11) = reduce((L <@> k0) <&!> (L <@> k1) <&!> (L <@> k00) <&!> (L <@> k01) <&!> (L <@> k11), (+))
// EXPECT: p0 = 7.0
// EXPECT: p1 = 12.0
// EXPECT: p00 = 21.0
// EXPECT: p01 = 29.0
// EXPECT: p11 = 50.0

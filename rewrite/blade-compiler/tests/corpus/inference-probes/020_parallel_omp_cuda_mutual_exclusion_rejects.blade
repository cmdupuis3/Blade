// TEST: Parallel: omp+cuda Mutual Exclusion (rejects)
// Mixed parallelism allows `mpi, omp(...)` and `mpi, cuda(...)` (outer,
// inner). A single kernel cannot be BOTH OpenMP-host and CUDA-device —
// one iteration space, two owners — so omp-then-cuda still rejects at
// parse time (with steering to `where cuda` for the device kernel).
let A = [1.0, 2.0, 3.0]
let L = method_for(A, A)
let f = lambda(x, y) where comm(x, y), omp(x: 1), cuda(block: 64) -> x * y
let result = L <@> f |> compute
// EXPECT: parse failure — a single kernel cannot be both OpenMP-host and CUDA-device

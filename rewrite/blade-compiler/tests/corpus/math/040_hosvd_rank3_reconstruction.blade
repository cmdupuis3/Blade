// TEST: Math hosvd: rank-3 full reconstruction
// X ≈ G ×₀ U0 ×₁ U1 ×₂ U2 with the full (untruncated) HOSVD is exact;
// ‖X − X̂‖² computed in-program pins at 0.0. Fixture: 3x3x3 with
// X(i,j,k) = (i+1)(j+2) + 0.5k² + 0.25ijk (math/OracleDump.fs).
import math as m
let X: Array<Float64 like Idx<3>, Idx<3>, Idx<3>> = [[[2.0, 2.5, 4.0], [3.0, 3.5, 5.0], [4.0, 4.5, 6.0]], [[4.0, 4.5, 6.0], [6.0, 6.75, 8.5], [8.0, 9.0, 11.0]], [[6.0, 6.5, 8.0], [9.0, 10.0, 12.0], [12.0, 13.5, 16.0]]]
let (G, U0, U1, U2) = m.hosvd(X)
let resid = {
    // X̂ = G ×₀ U0 ×₁ U1 ×₂ U2 : build the rank-6 term tensor
    // T(i,j,k,a,b,c) = G(a,b,c)·U0(i,a)·U1(j,b)·U2(k,c) with the output modes
    // (i,j,k) leading and the contracted core modes (a,b,c) trailing, then
    // collapse each (a,b,c) fibre with a reduce to recover X̂(i,j,k).
    let T = method_for(range<Idx<3>, Idx<3>, Idx<3>, Idx<3>, Idx<3>, Idx<3>>) <@> lambda(i, j, k, a, b, c) -> G(a, b, c) * U0(i, a) * U1(j, b) * U2(k, c) |> compute
    let Xhat = method_for(T) <@> lambda(sub: Array<Float64 like Idx<3>, Idx<3>, Idx<3>>) -> reduce(sub, (+)) |> compute
    let E = Xhat - X
    reduce(E, lambda(acc, x) -> acc + x * x, 0.0)
}
// EXPECT: resid = 0.0

// TEST: Spectra fft2: Parseval at 6x4 (naive rows axis, radix-2 cols axis)
// sum|X|^2 = r*c * sum x^2 for the unnormalized transform. Both sums are
// accumulated in row-major order exactly as the oracle does; the residual
// comes out exactly 0 here (pinned from spectra/OracleDump.fs). The 6-row
// axis takes the naive table-DFT path, the 4-col axis the radix-2 path.
import spectra as sp
let x: Array<Float64 like Idx<6>, Idx<4>> = [[-3.0, -2.5, -2.0, -1.5], [-1.0, -0.5, 0.0, 0.5], [1.0, 1.5, 2.0, 2.5], [3.0, 3.5, 4.0, 4.5], [5.0, 5.5, 6.0, 6.5], [7.0, 7.5, 8.0, 8.5]]
let X = sp.fft2(x)
let resid = {
    let sx = reduce(method_for(range<Idx<6>>) <*> method_for(range<Idx<4>>) <@> lambda(i, j) -> x(i, j) * x(i, j), (+), 0.0)
    let sX = reduce(method_for(range<Idx<6>>) <*> method_for(range<Idx<4>>) <@> lambda(i, j) -> real(X(i, j)) * real(X(i, j)) + imag(X(i, j)) * imag(X(i, j)), (+), 0.0)
    sX - 24.0 * sx
}
// EXPECT: resid = 0.0

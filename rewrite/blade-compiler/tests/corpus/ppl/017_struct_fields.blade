// TEST: Struct Fields
// Formers over struct-field paths: m.X normalizes to an alias binding
// (`let __ppl_arr_m_X = m.X`) before the pipeline — codegen iterates named
// bindings. WITHOUT a declared indep the cross block is computed: same
// data as ppl/005, so the same nonzero values.
type TimeIdx = Idx<2>
struct Pair {
    X: Array<Float64 like Idx<2>, TimeIdx>,
    Y: Array<Float64 like Idx<3>, TimeIdx>
}
let m = Pair { X = [[1.0, 2.0], [3.0, 5.0]], Y = [[2.0, 4.0], [1.0, 1.0], [0.0, 2.0]] }
let mom = moments(m.X, 2)
let c = comoments(m.X, m.Y)
// EXPECT: mom = [2.5, 6.5, 17.0]
// EXPECT: c = [0.5, 0.0, 0.5, 1.0, 0.0, 1.0]

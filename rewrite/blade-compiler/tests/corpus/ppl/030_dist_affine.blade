// TEST: Dist Affine
// dist_affine(W, d): κ'_k = W^⊗k κ_k — multilinearity under a linear map,
// the exact-linear case of the Faà di Bruno pushforward, unrolled
// cell-wise (W read at runtime; the contraction structure is static).
// Data A: κ1 = [1.5, 3.5], κ2 ≡ 0.25, κ3 = 0. W = [[1,2],[0,1]], row sums
// [3, 1]: kp1 = W·κ1 = [8.5, 3.5]; kp2 = 0.25·(rowsum ⊗ rowsum) =
// [2.25, 0.75, 0.25]; kp3 = 0 (zero preservation).
type TimeIdx = Idx<2>
let A: Array<Float64 like Idx<2>, TimeIdx> = [[1.0, 2.0], [3.0, 4.0]]
let W: Array<Float64 like Idx<2>, Idx<2>> = [[1.0, 2.0], [0.0, 1.0]]
let d = dist(A, 3)
let (p1, p2, p3) = dist_affine(W, d)
// EXPECT: p1 = [8.5, 3.5]
// EXPECT: p2 = [2.25, 0.75, 0.25]
// EXPECT: p3 = [0.0, 0.0, 0.0, 0.0]

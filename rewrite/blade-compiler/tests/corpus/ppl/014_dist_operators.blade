// TEST: Dist Operators
// Operator surface on dist bindings (elaboration-level; typed Dist<r, τ>
// dispatch is the successor): + and - are per-order cumulant combination
// (independence-gated; κ_k(−Y) = (−1)^k κ_k(Y) so even orders ADD under
// subtraction), scalar * is c^k multilinearity from either side.
// s2 = [0.25,0.25,0.25]+[0,0,1] | w1 = [1.5-2, 3.5-2] | w2 = s2 | h2 = 4·κ2(X)
type TimeIdx = Idx<2>
let X: Array<Float64 like Idx<2>, TimeIdx> = [[1.0, 2.0], [3.0, 4.0]]
let Y: Array<Float64 like Idx<2>, TimeIdx> = [[2.0, 2.0], [1.0, 3.0]]
let _ = independent(X, Y)
let dx = dist(X, 2)
let dy = dist(Y, 2)
let s = dx + dy
let w = dx - dy
let h = 2.0 * dx
let s2 = cumulant(s, 2)
let w1 = cumulant(w, 1)
let w2 = cumulant(w, 2)
let h2 = cumulant(h, 2)
// EXPECT: s2 = [0.25, 0.25, 1.25]
// EXPECT: w1 = [-0.5, 1.5]
// EXPECT: w2 = [0.25, 0.25, 1.25]
// EXPECT: h2 = [1.0, 1.0, 1.0]

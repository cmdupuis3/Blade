// TEST: Rand Distinct Keys
// Different keys produce different streams (the SplitMix64 finalizer
// decorrelates nearby keys before seeding). Two length-64 uniform draws with
// adjacent keys must differ, checked via their sums.
import rand as r
let a = r.uniform(1, 64)
let b = r.uniform(2, 64)
let sa = reduce(a, (+))
let sb = reduce(b, (+))
let differ = abs(sa - sb) > 0.0001
// EXPECT: differ = true

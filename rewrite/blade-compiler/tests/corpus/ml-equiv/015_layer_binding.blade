// TEST: ML Equiv Layer Binding Form
import ml as ml
// ============================================================================
// The declarative surface: `let layer = ml.derive_linear(SIN, SOUT)` binds
// the compiler-written layer as a FUNCTION VALUE; calls flow through the
// normal FuncElem path. Values = 011's (same specs, weights, input).
// ============================================================================
let static SIN = [(0, 0, 2), (1, 1, 1)]
let static SOUT = [(0, 0, 1), (1, 1, 2)]
let layer1 = ml.derive_linear(SIN, SOUT)
let out = layer1([0.5, -1.0, 2.0, 0.25], [1.0, 2.0, 3.0, -1.0, 0.5])
// EXPECT: out = [-1.5, 6.0, -2.0, 1.0, 0.75, -0.25, 0.125]

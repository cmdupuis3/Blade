// TEST: ML Equiv Gated O3 Parity Premise (rejects)
import ml as ml
// ============================================================================
// The F2 premise, finally CHECKED: gated reads its gates from block 0, and
// sigmoid of a PSEUDOSCALAR (l=0, odd) is not O(3)-equivariant — under an
// improper rotation the gate input flips sign but sigmoid is not odd.
// equiv(SO3) admits this same spec (see 010). BL4008.
// ============================================================================
let static SODD = [(0, 1, 1), (1, 1, 1)]
function bad(x: Array<Float like IrrepsIdx<SODD>>) where ml.equiv(O3) -> Array<Float like IrrepsIdx<SODD>> =
  ml.gated(SODD, x)

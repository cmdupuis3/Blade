// TEST: Mutual Lone Member Annotation (rejects)
// A member type used without its partners is a compile error.
struct Particle {
    pos: Float,
    vel: Float,
    mass: Float
}
type P1 = Particle
and P2 = Particle
where P1.vel + P2.vel == 0.0
let lone: P1 = Particle { pos = 0.0, vel = 1.0, mass = 1.0 }

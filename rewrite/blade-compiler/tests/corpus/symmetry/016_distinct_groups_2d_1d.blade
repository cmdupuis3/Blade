// TEST: Distinct Comm Groups Multiply (2D and 1D)
// Product symmetry across GROUPS is sound and multiplies: (A, A, B, B) with
// comm(x, y) and comm(z, w) yields SymIdx<2, 4> (joint over A's 2x2 compound
// space) x SymIdx<2, 2> (over B) — speedup 2! * 2! = 4. The factors come from
// distinct identity groups, never from the data dimensions of one group.
// a = [1,2,3,4] flat; b = [10,20]; pair products bq = [100, 200, 400].
let A: Array<Float64 like Idx<2>, Idx<2>> = [[1.0, 2.0], [3.0, 4.0]]
let B = [10.0, 20.0]
let L = method_for(A, A, B, B)
let f = lambda(x, y, z, w) where comm(x, y), comm(z, w) -> x * y * z * w
let result = L <@> f |> compute
// A-pairs lex: 1,2,3,4,4,6,8,9,12,16; each expands by [100, 200, 400]
// EXPECT: result = [100.0, 200.0, 400.0, 200.0, 400.0, 800.0, 300.0, 600.0, 1200.0, 400.0, 800.0, 1600.0, 400.0, 800.0, 1600.0, 600.0, 1200.0, 2400.0, 800.0, 1600.0, 3200.0, 900.0, 1800.0, 3600.0, 1200.0, 2400.0, 4800.0, 1600.0, 3200.0, 6400.0]

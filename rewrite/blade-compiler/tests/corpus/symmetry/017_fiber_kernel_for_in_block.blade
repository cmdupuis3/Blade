// TEST: For-In Inside Inlined Fiber Kernel
// REGRESSION: a block kernel { let mut s; for .. { s = s + .. }; s } passed
// to method_for(A, A) <@> k is inlined at the apply site by genLoopNest via
// exprToCpp. renderLetExpr used to DROP unit-valued let chain links
// (IRAssign / IRForRange sequenced through dummy lets by lowerTypedBlock),
// so the inlined kernel returned the init value unchanged: every output
// cell was 0.0 with no diagnostic. Statement forms now render inside the
// IIFE. Fiber dot products over A = [[1,2],[3,4]], comm kernel, upper
// triangle: (0,0) = 1*1+2*2 = 5; (0,1) = 1*3+2*4 = 11; (1,1) = 3*3+4*4 = 25.
type TimeIdx = Idx<2>
let A: Array<Float64 like Idx<2>, TimeIdx> = [[1.0, 2.0], [3.0, 4.0]]
let L = method_for(A, A)
let k = lambda(a: Array<Float64 like TimeIdx>, b: Array<Float64 like TimeIdx>) where comm(a, b) -> {
    let mut s = 0.0
    for t in 0..2 {
        s = s + a(t) * b(t)
    }
    s
}
let r = L <@> k |> compute
// EXPECT: r = [5.0, 11.0, 25.0]

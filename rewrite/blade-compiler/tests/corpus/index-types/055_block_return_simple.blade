// TEST: Block Return Simple
// ============================================================================
// Block expression return value tests
// ============================================================================
// ============================================================================
// Block expression return value tests
// ============================================================================
// Block should return its final expression
function f(x: Float64) -> Float64 = {
    let y = x * 2.0
    y + 1.0
}
let r = f(5.0)
// EXPECT: r = 11

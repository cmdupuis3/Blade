// TEST: Sequence Two
// ============================================================================
// Sequence combinator tests
// ============================================================================
// ============================================================================
// Sequence combinator tests
// ============================================================================
// sequence(c1, c2) produces array indexed by Idx<2>
let A = [1.0, 2.0, 3.0]
let L = method_for(A)
let f = lambda(x) -> x + 10.0
let g = lambda(x) -> x * 2.0
let result = sequence(L <@> f, L <@> g) |> compute
// EXPECT: result = [11.0, 12.0, 13.0, 2.0, 4.0, 6.0]

// TEST: Antijoin Basic
// Antijoin: elements of A NOT in B. Pattern is mask(A, !contains(B, x)).
let A = [1, 2, 3, 4, 5, 6, 7]
let B = [2, 4, 6]
let r = compound(A, mask(A, lambda(x) -> !contains(B, x)))
// present coordinates {0, 2, 4, 6} = 1, 3, 5, 7
let n = extents(r)
let x0 = r(0)
let x6 = r(6)
// EXPECT: n = 4
// EXPECT: x0 = 1
// EXPECT: x6 = 7

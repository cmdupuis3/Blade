// TEST: Static Match
// Static function with match expression
static function dim(l) = match l with
    | 0 -> 1
    | 1 -> 3
    | 2 -> 5
    | _ -> 2 * l + 1
let static d0 = dim(0)
let static d1 = dim(1)
let static d2 = dim(2)
let static d3 = dim(3)
let a = d0
let b = d1
let c = d2
let d = d3
// EXPECT: a = 1
// EXPECT: b = 3
// EXPECT: c = 5
// EXPECT: d = 7

// TEST: Static For Former
// `static for (...)` — the for-spelling of the former carries the marker
// through its desugar; the staged argument list elaborates identically.
static function rep(x, k) = if k == 1 then x else (x, rep(x, k - 1))
let A = [2.0, 3.0]
let sf = static for (rep(A, 2)) <@> lambda(x, y) -> x * y |> compute
// EXPECT: sf = [4, 6, 6, 9]

// TEST: Static Struct Bound Violated (rejects)
// A desugared field-range bound (shared Ast.structConjuncts helper) is
// checked at fold time exactly like a declared where-conjunct.
struct CGPath {
    l1: Int,
    l2: Int,
    l_out: Int in abs(l1 - l2) .. l1 + l2 + 1
}
let static bad = CGPath { l1 = 1, l2 = 2, l_out = 5 }

// TEST: Reduce Deferred Grid
// Fused fold over a multi-dim Cartesian pipeline (the sum-reduce over a
// full method_for(A, B) grid), the 3-arg init form, and the (*) section's
// implicit identity seed (1).
let A = [1.0, 2.0, 3.0]
let B = [4.0, 5.0, 6.0]
let grid = reduce(method_for(A, B) <@> lambda(x, y) -> x * y, (+))
let grid_init = reduce(method_for(A, B) <@> lambda(x, y) -> x * y, (+), 100.0)
let prod = reduce(method_for(A) <@> lambda(x) -> x + 1.0, (*))
// grid = (1+2+3)*(4+5+6) = 90; grid_init = 190; prod = 2*3*4 = 24
// EXPECT: grid = 90.0
// EXPECT: grid_init = 190.0
// EXPECT: prod = 24.0

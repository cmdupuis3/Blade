// TEST: Replicate Basic
// ============================================================================
// Replicate Tests
// ============================================================================
// ============================================================================
// Replicate Tests
// ============================================================================
// replicate(3, c) produces array with 3 copies
let A = [1.0, 2.0, 3.0]
let L = method_for(A)
let c = L <@> lambda(x) -> x + 10.0
let result = replicate(3, c) |> compute
// EXPECT: result = [11.0, 12.0, 13.0, 11.0, 12.0, 13.0, 11.0, 12.0, 13.0]

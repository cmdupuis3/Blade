// TEST: Union A Subsumes B
// When all of B is already in A, union equals dedup(A). Tests that the
// B-loop's seen-check correctly suppresses everything.
let A = [1, 2, 3, 2, 1]
let B = [1, 3]
let r = union(A, B)
let result = method_for(r) <@> lambda(x) -> x |> compute
// EXPECT: result = [1, 2, 3]

// TEST: SGS Formers Values
import sgs as sgs
// ============================================================================
// The sgs field formers as elaborated ops over the N=4 divergence-free
// field (the same field as sgs/004-005, baked by the oracle as a rank-4
// literal so everything pins bit-exactly):
//   sgs.grad(U, dx)      -> (3, 3, 4, 4, 4)  G(c,d,i,j,k) = d_d u_c
//   sgs.box_filter(U, 2) -> (3, 2, 2, 2)     tile means
//   sgs.stress(U, 2)     -> (6, 2, 2, 2)     exact subgrid stress, packed
// Physics pins: the g22 slots are exactly 0 (u_2 is z-independent), the
// gradient trace vanishes at every point (div-free BY the op's own
// difference operator), cell (0,0,0) of the stress reproduces the sgs/005
// tile pins, and the filtered means match the 005 mu pins.
// ============================================================================
let U: Array<Float64 like Idx<3>, Idx<4>, Idx<4>, Idx<4>> = [[[[0.4502502767118629, -0.2542796605492269, -0.31459191057262553, 0.38993802668846417], [0.30415439769464864, -0.4003755395664412, -0.4606877895898398, 0.2438421476712499], [0.31459191057262503, -0.3899380266884648, -0.4502502767118634, 0.2542796605492263], [0.4606877895898401, -0.24384214767124973, -0.30415439769464836, 0.40037553956644134]], [[0.15435992254473935, -0.5501700147163504, -0.6104822647397491, 0.09404767252134061], [-0.49111216032904575, -1.1956420975901356, -1.2559543476135342, -0.5514244103524445], [0.610482264739749, -0.09404767252134089, -0.15435992254473951, 0.5501700147163502], [1.255954347613534, 0.5514244103524442, 0.4911121603290455, 1.1956420975901352]], [[0.9496264805684338, 0.24509654330734393, 0.1847842932839453, 0.889314230545035], [-0.7870025144961696, -1.4915324517572595, -1.551844701780658, -0.8473147645195684], [-0.18478429328394536, -0.8893142305450352, -0.9496264805684338, -0.2450965433073441], [1.5518447017806583, 0.8473147645195684, 0.7870025144961698, 1.4915324517572595]], [[1.2455168347355574, 0.5409868974744676, 0.480674647451069, 1.1852045847121588], [0.008264043527524745, -0.6962658937335651, -0.7565781437569636, -0.052048206495873994], [-0.48067464745106886, -1.1852045847121586, -1.2455168347355574, -0.5409868974744676], [0.7565781437569636, 0.05204820649587388, -0.008264043527524745, 0.696265893733565]]], [[[0.05567577700150628, 0.901111701714814, 0.9734864017428924, 0.12805047702958477], [0.8509423350252009, 1.6963782597385086, 1.768752959766587, 0.9233170350532793], [0.555051980858077, 1.4004879055713848, 1.4728626055994631, 0.6274266808861555], [-0.2402145771656169, 0.6052213475476909, 0.6775960475757692, -0.1678398771375384]], [[-1.2408999337951738, -0.39546400908186596, -0.32308930905378763, -1.1685252337670953], [-0.94500957962805, -0.0995736549147423, -0.027198954886663962, -0.8726348795999715], [-0.1497430216043556, 0.6956929031089522, 0.7680676031370305, -0.0773683215762771], [-0.44563337577147966, 0.3998025489418281, 0.4721772489699064, -0.3732586757434011]], [[-0.9734864017428926, -0.12805047702958483, -0.0556757770015065, -0.901111701714814], [-1.7687529597665872, -0.9233170350532793, -0.850942335025201, -1.6963782597385086], [-1.4728626055994631, -0.6274266808861555, -0.5550519808580772, -1.4004879055713848], [-0.6775960475757684, 0.16783987713753934, 0.24021457716561767, -0.60522134754769]], [[0.3230893090537874, 1.1685252337670953, 1.2408999337951734, 0.3954640090818659], [0.027198954886663518, 0.8726348795999712, 0.9450095796280495, 0.09957365491474202], [-0.7680676031370304, 0.07736832157627738, 0.1497430216043557, -0.6956929031089518], [-0.47217724896990676, 0.373258675743401, 0.4456333757714793, -0.3998025489418282]]], [[[0.07830235689985615, 0.07830235689985615, 0.07830235689985615, 0.07830235689985615], [-1.6525188727304907, -1.6525188727304907, -1.6525188727304907, -1.6525188727304907], [-1.033638846025462, -1.033638846025462, -1.033638846025462, -1.033638846025462], [0.697182383604884, 0.697182383604884, 0.697182383604884, 0.697182383604884]], [[1.1475662360440144, 1.1475662360440144, 1.1475662360440144, 1.1475662360440144], [0.1658093121985236, 0.1658093121985236, 0.1658093121985236, 0.1658093121985236], [-0.8520460293826752, -0.8520460293826752, -0.8520460293826752, -0.8520460293826752], [0.12971089446281614, 0.12971089446281614, 0.12971089446281614, 0.12971089446281614]], [[0.28457454024060597, 0.28457454024060597, 0.28457454024060597, 0.28457454024060597], [0.9395529846813426, 0.9395529846813426, 0.9395529846813426, 0.9395529846813426], [0.6707619488849996, 0.6707619488849996, 0.6707619488849996, 0.6707619488849996], [0.015783504444262686, 0.015783504444262686, 0.015783504444262686, 0.015783504444262686]], [[-0.7846893389035523, -0.7846893389035523, -0.7846893389035523, -0.7846893389035523], [-0.8787752002476716, -0.8787752002476716, -0.8787752002476716, -0.8787752002476716], [0.48916913224221226, 0.48916913224221226, 0.48916913224221226, 0.48916913224221226], [0.583254993586332, 0.583254993586332, 0.583254993586332, 0.583254993586332]]]]
let dx = 3.141592653589793 / 2.0

let G = sgs.grad(U, dx)
let g00_000 = G(0, 0, 0, 0, 0)
// EXPECT: g00_000 = -0.3473260325281158
let g01_000 = G(0, 1, 0, 0, 0)
// EXPECT: g01_000 = -0.04982612615812109
let g12_000 = G(1, 2, 0, 0, 0)
// EXPECT: g12_000 = 0.2460730304426572
let g21_123 = G(2, 1, 1, 2, 3)
// EXPECT: g21_123 = -0.011490483240867972
let g10_123 = G(1, 0, 1, 2, 3)
// EXPECT: g10_123 = -0.6455052612057486
let g22_123 = G(2, 2, 1, 2, 3)
// EXPECT: g22_123 = 0.0

// divergence via the op's own difference operator: trace(G) = 0 pointwise
let mut dv = [0.0]
let div_done = {
    for i in 0..4 {
        for j in 0..4 {
            for k in 0..4 {
                let d = G(0, 0, i, j, k) + G(1, 1, i, j, k) + G(2, 2, i, j, k)
                dv(0) += d * d
            }
        }
    }
    0.0
}
let field_is_divergence_free = if dv(0) < 0.00000000000000000000000001 then 1.0 else 0.0
// EXPECT: field_is_divergence_free = 1.0

let F = sgs.box_filter(U, 2)
let f0_000 = F(0, 0, 0, 0)
// EXPECT: f0_000 = -0.24785185947499364
let f1_011 = F(1, 0, 1, 1)
// EXPECT: f1_011 = 0.4249579139638885
let f2_110 = F(2, 1, 1, 0)
// EXPECT: f2_110 = 0.43974239478945165

let S = sgs.stress(U, 2)
let s0_000 = S(0, 0, 0, 0)
// EXPECT: s0_000 = 0.25325184801754563
let s1_000 = S(1, 0, 0, 0)
// EXPECT: s1_000 = 0.023596559909789594
let s2_000 = S(2, 0, 0, 0)
// EXPECT: s2_000 = -0.08610568558444831
let s3_000 = S(3, 0, 0, 0)
// EXPECT: s3_000 = 0.8664234203346481
let s4_000 = S(4, 0, 0, 0)
// EXPECT: s4_000 = -0.7664919700416585
let s5_000 = S(5, 0, 0, 0)
// EXPECT: s5_000 = 1.0160853438383561
let s0_111 = S(0, 1, 1, 1)
// EXPECT: s0_111 = 0.7668389130445367
let s5_111 = S(5, 1, 1, 1)
// EXPECT: s5_111 = 0.06403751086647208

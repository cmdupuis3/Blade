// TEST: Free Function Calls Capturing Function
// A function whose body references a module-level binding emits as a
// std::function lambda INSIDE main() (it captures the binding). Any
// function that CALLS it must therefore be main-local too — main-locality
// is transitive (computeMainLocalFuncIds in CodeGen.fs). Before that fix,
// `f` emitted as a free C++ function referencing the main-scoped `g` and
// C++ compilation failed with "'g' was not declared in this scope".
// `pure_fn` pins the negative: no module refs anywhere in its call graph,
// so it stays a free function.
let static K = 4.0
static function g(x: Float) -> Float = x + K
function f(y: Float) -> Float = g(y)
function h(z: Float) -> Float = f(z) * 2.0
function pure_fn(w: Float) -> Float = w + 1.0
let r = h(1.0)
let s = pure_fn(r)
// EXPECT: r = 10
// EXPECT: s = 11

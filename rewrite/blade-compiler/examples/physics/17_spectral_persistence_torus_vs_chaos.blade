// --- regular (E = 0.0185): packed pair covariances; the like Idx<4> pack is
// LEX-ordered, so the (0,k) cells sit at flat indices 1, 2, 3 ---
let cR = ppl.cumulants(REG, 2)
let R_C0 = cR(0)
let R_Ca = cR(1)
let R_Cb = cR(2)
let R_Cc = cR(3)
let R_pers = sqrt((R_Ca * R_Ca + R_Cb * R_Cb + R_Cc * R_Cc) / 3.0) / R_C0
let R_V = if R_pers > 0.3 then "PERSISTS" else "DECAYS"

// --- chaotic (E = 0.153) ---
let cC = ppl.cumulants(CHA, 2)
let C_C0 = cC(0)
let C_Ca = cC(1)
let C_Cb = cC(2)
let C_Cc = cC(3)
let C_pers = sqrt((C_Ca * C_Ca + C_Cb * C_Cb + C_Cc * C_Cc) / 3.0) / C_C0
let C_V = if C_pers > 0.3 then "PERSISTS" else "DECAYS"

// discrete spectrum persists (torus); continuous spectrum decays (mixing):
// EXPECT: R_C0 = 0.0261873063644517
// EXPECT: R_pers = 0.779898328972411
// EXPECT: R_V = "PERSISTS"
// EXPECT: C_C0 = 0.261760966022615
// EXPECT: C_pers = 0.0583267628839762
// EXPECT: C_V = "DECAYS"
, 0.0, 0.0, 0.0]
    let mut x = 0.0
    let mut p = 0.0
    for j in 0..32 {
        x = AMPS(j)
        p = 0.0
        for t in 0..14000 {
            let sm = t - (t / 35) * 35
            let g = if sm < 1 then 1.0 else 0.0
            s(t / 35) = s(t / 35) + g * x / 32.0
            let f0 = 0.0 - x - 0.2 * x * x * x
            let ph = p + 0.005 * f0
            x = x + 0.01 * ph
            let f1 = 0.0 - x - 0.2 * x * x * x
            p = ph + 0.005 * f1
        }
    }
    s
}

// ---- delay-embedded EDMD, quantum ----
// The 10-delay embedding is a halo view: reach [-9, +1] shrinks the 400-sample
// signal to its 390-cell interior (t = 9..398, exactly the old hand-loop
// bounds), and embedding row i reads the window at offset -i (the one-step
// lead copy at 1 - i). The Gram and cross-Gram are then row-pair prodsum
// sweeps -- no flat stat vector, no ring reads, no pack/unpack offsets.
let EQ = method_for(range<Idx<10>, halo<Idx<400>, [-9, 1]>>) <@> lambda(i, w) -> SIGQ(w(0 - i)) |> compute
let E1Q = method_for(range<Idx<10>, halo<Idx<400>, [-9, 1]>>) <@> lambda(i, w) -> SIGQ(w(1 - i)) |> compute
let GQ: Array<Float64 like Idx<10>, Idx<10>> = method_for(EQ, EQ) <@> lambda(u: Array<Float64 like Idx<390>>, v: Array<Float64 like Idx<390>>) -> prodsum(u, v) |> compute
let AQ = method_for(E1Q, EQ) <@> lambda(u: Array<Float64 like Idx<390>>, v: Array<Float64 like Idx<390>>) -> prodsum(u, v) |> compute
let (QGQ, LGQ) = m.eigh(GQ)
// spectrally truncated inverse: directions below resolution go to zero, not leakage
let QDQ = method_for(range<Idx<10>>) <*> method_for(range<Idx<10>>) <@> lambda(i: Int64, k: Int64) -> QGQ(i, k) * (if LGQ(k) > LGQ(0) * 0.000000001 then 1.0 / LGQ(k) else 0.0) |> compute
let GIQ = method_for(QDQ, QGQ) <@> lambda(u: Array<Float64 like Idx<10>>, v: Array<Float64 like Idx<10>>) -> prodsum(u, v) |> compute
let KMQ: Array<Float64 like Idx<10>, Idx<10>> = method_for(AQ, GIQ) <@> lambda(u: Array<Float64 like Idx<10>>, v: Array<Float64 like Idx<10>>) -> prodsum(u, v) |> compute
let (REQ, IMQ) = m.eig(KMQ)

// ---- delay-embedded EDMD, classical ----
// Same halo embedding over the classical ensemble mean.
let EC = method_for(range<Idx<10>, halo<Idx<400>, [-9, 1]>>) <@> lambda(i, w) -> SIGC(w(0 - i)) |> compute
let E1C = method_for(range<Idx<10>, halo<Idx<400>, [-9, 1]>>) <@> lambda(i, w) -> SIGC(w(1 - i)) |> compute
let GC: Array<Float64 like Idx<10>, Idx<10>> = method_for(EC, EC) <@> lambda(u: Array<Float64 like Idx<390>>, v: Array<Float64 like Idx<390>>) -> prodsum(u, v) |> compute
let AC = method_for(E1C, EC) <@> lambda(u: Array<Float64 like Idx<390>>, v: Array<Float64 like Idx<390>>) -> prodsum(u, v) |> compute
let (QGC, LGC) = m.eigh(GC)
// spectrally truncated inverse: directions below resolution go to zero, not leakage
let QDC = method_for(range<Idx<10>>) <*> method_for(range<Idx<10>>) <@> lambda(i: Int64, k: Int64) -> QGC(i, k) * (if LGC(k) > LGC(0) * 0.000000001 then 1.0 / LGC(k) else 0.0) |> compute
let GIC = method_for(QDC, QGC) <@> lambda(u: Array<Float64 like Idx<10>>, v: Array<Float64 like Idx<10>>) -> prodsum(u, v) |> compute
let KMC: Array<Float64 like Idx<10>, Idx<10>> = method_for(AC, GIC) <@> lambda(u: Array<Float64 like Idx<10>>, v: Array<Float64 like Idx<10>>) -> prodsum(u, v) |> compute
let (REC, IMC) = m.eig(KMC)

// ---- meters: unitarity + gap match vs the certified spectrum ----
let cg1 = cos((EV(1) - EV(0)) * 0.35)
let cg2 = cos((EV(2) - EV(1)) * 0.35)
let cg3 = cos((EV(3) - EV(2)) * 0.35)
// the Delta-n = 3 satellite gaps, from the certified spectrum
let cgA = cos((EV(3) - EV(0)) * 0.35)
let cgB = cos((EV(4) - EV(1)) * 0.35)
let agap = (EV(2) - EV(1)) - (EV(1) - EV(0))
function amin2(a: Float64, b: Float64) -> Float64 = if a < b then a else b
// the two dominant pairs: cosines vs the certified adjacent gaps, tight
let devCos = {
    let mut worst = 0.0
    for k in 0..4 {
        let md = sqrt(REQ(k) * REQ(k) + IMQ(k) * IMQ(k))
        let cv = REQ(k) / md
        let d1 = abs(cv - cg1)
        let d2 = abs(cv - cg2)
        let best = amin2(d1, d2)
        worst = if best > worst then best else worst
    }
    worst
}
// unitarity of the two dominant pairs
let devMod = {
    let mut worst = 0.0
    for k in 0..4 {
        let md = sqrt(REQ(k) * REQ(k) + IMQ(k) * IMQ(k))
        let d = abs(md - 1.0)
        worst = if d > worst then d else worst
    }
    worst
}
// resolution meter: best match anywhere in the spectrum to the
// Delta-n = 3 satellite gap of the certified ladder (the ex 18 line)
let hitS = {
    let mut best = 1.0
    for k in 0..10 {
        let md = sqrt(REQ(k) * REQ(k) + IMQ(k) * IMQ(k))
        let cv = REQ(k) / (if md > 0.000001 then md else 1.0)
        let d = abs(cv - cgB)
        best = if d < best then d else best
    }
    best
}
// classical: the LARGEST modulus of the fitted operator
let maxModC = {
    let mut worst = 0.0
    for k in 0..10 {
        let md = sqrt(REC(k) * REC(k) + IMC(k) * IMC(k))
        worst = if md > worst then md else worst
    }
    worst
}

// ---- verdicts ----
let certV = if certQ < 0.0000000000000001 then (if orthQ < 0.0000000000000001 then "EIGENFACTOR_CERTIFIED" else "NO") else "NO"
let circleV = if devMod < 0.002 then "BOHR_LINES_ON_UNIT_CIRCLE" else "NO"
let gapsV = if devCos < 0.001 then "GAPS_MATCH_CERTIFIED_SPECTRUM" else "NO"
let satV = if hitS < 0.002 then "DELTA3_SATELLITE_RESOLVED" else "NO"
let unevenV = if agap > 0.05 then "ANHARMONIC_LADDER_UNEVEN" else "NO"
let dephV = if maxModC < 0.999 then "CLASSICAL_MEAN_DEPHASES_INSIDE_DISK" else "NO"
let req0 = REQ(0)
let imq0 = IMQ(0)
let req2 = REQ(2)
let imq2 = IMQ(2)

// certified spectrum in, Bohr gaps out; the classical twin leaks into the disk:

let s1234 = reduce(method_for(zip(WT, Z1, Z2, Z3, Z4)) <@> lambda(w, a, b, c, d) -> w * a * b * c * d, (+)) / 729.0
let s1235 = reduce(method_for(zip(WT, Z1, Z2, Z3, Z5)) <@> lambda(w, a, b, c, d) -> w * a * b * c * d, (+)) / 729.0

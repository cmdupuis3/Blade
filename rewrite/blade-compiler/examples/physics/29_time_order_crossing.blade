let w34 = reduce(method_for(zip(WT, Z3, Z4)) <@> lambda(w, a, b) -> w * a * b, (+)) / 729.0
let w35 = reduce(method_for(zip(WT, Z3, Z5)) <@> lambda(w, a, b) -> w * a * b, (+)) / 729.0
let w36 = reduce(method_for(zip(WT, Z3, Z6)) <@> lambda(w, a, b) -> w * a * b, (+)) / 729.0

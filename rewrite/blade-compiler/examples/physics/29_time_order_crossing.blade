let kw3456 = s3456 - w34 * w56 - w35 * w46 - w36 * w45
let nposW = (if kw1234 > 0.0 then 1.0 else 0.0) + (if kw1235 > 0.0 then 1.0 else 0.0) + (if kw1236 > 0.0 then 1.0 else 0.0) + (if kw1245 > 0.0 then 1.0 else 0.0) + (if kw1246 > 0.0 then 1.0 else 0.0) + (if kw1256 > 0.0 then 1.0 else 0.0) + (if kw1345 > 0.0 then 1.0 else 0.0) + (if kw1346 > 0.0 then 1.0 else 0.0) + (if kw1356 > 0.0 then 1.0 else 0.0) + (if kw1456 > 0.0 then 1.0 else 0.0) + (if kw2345 > 0.0 then 1.0 else 0.0) + (if kw2346 > 0.0 then 1.0 else 0.0) + (if kw2356 > 0.0 then 1.0 else 0.0) + (if kw2456 > 0.0 then 1.0 else 0.0) + (if kw3456 > 0.0 then 1.0 else 0.0)

// --- verdicts ---
let sign_V = if npos < 0.5 then "ALL_K4_NEGATIVE" else (if npos > 14.5 then "ALL_K4_POSITIVE" else "MIXED_SIGNS")
let collapse_V = if g_rsd < 0.25 then "CONSTANT_Q" else "NOT_A_Q_FAMILY"
let below_V = if n_below_free > 0.5 then "DEFICIT_EXCEEDS_CROSSING_CHANNEL" else "WITHIN_Q_RANGE"
let flip_V = if nposW > 14.5 then "K4_FLIPS_WITH_JET_SHAPE" else (if nposW < 0.5 then "K4_SIGN_ROBUST" else "PARTIAL_FLIP")
let verdict_V = if nposW > 14.5 then "INHERITED_NOT_DYNAMICAL" else "DYNAMICAL_STRUCTURE"


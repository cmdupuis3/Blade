let dmaxN = {
    let mut best = 0.0
    for k in 0..8 {
        let em = STN(602 + k) / 1476.0
        let ev = STN(610 + k) / 1476.0 - em * em
        let rel = sqrt(sqrt(ev * ev)) / em
        best = if rel > best then rel else best
    }
    best
}
let lt12aN = LT12N(0)
let lt12dN = LT12N(3)
let lt12eN = LT12N(4)
let lt12iN = LT12N(8)
let lt24eN = LT24N(4)

// ---- verdicts ----
let cleanV = if lt12dC > 0.99 then (if lt12eC < 0.9 then "FOUR_INVARIANTS_AT_ONE" else "NO") else "NO"
let cosV = if sqrt((lt12eC - 0.825336) * (lt12eC - 0.825336)) < 0.05 then (if sqrt((lt12iC - 0.362358) * (lt12iC - 0.362358)) < 0.08 then "COS_CLUSTERS_AS_PREDICTED" else "NO") else "NO"
let killV = if dmaxC < 0.001 then (if dmaxN > 0.05 then "ZERO_VARIANCE_DETECTOR_KILLED" else "NO") else "NO"
let plateauV = if plN < 0.05 then (if omN > 0.1 then "INVARIANTS_PLATEAU_UNDER_NOISE" else "NO") else "NO"
let rayV = if sqrt((rE12N - rE24N) * (rE12N - rE24N)) < 0.02 then (if rE12N > 0.8 then (if sqrt((rO12N - rO24N) * (rO12N - rO24N)) > 0.5 then "ENERGY_PLATEAUS_OSCILLATOR_MOVES" else "NO") else "NO") else "NO"


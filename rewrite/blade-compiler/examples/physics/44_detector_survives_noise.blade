                dm(11) = dm(1) * dm(2)
                dm(12) = dm(1) * dm(3)
                dm(13) = dm(2) * dm(3)
                dl(0) = ring(4 * slotL)
                dl(1) = ring(4 * slotL + 1)
                dl(2) = ring(4 * slotL + 2)
                dl(3) = ring(4 * slotL + 3)
                dl(4) = dl(0) * dl(0)
                dl(5) = dl(1) * dl(1)
                dl(6) = dl(2) * dl(2)
                dl(7) = dl(3) * dl(3)
                dl(8) = dl(0) * dl(1)
                dl(9) = dl(0) * dl(2)
                dl(10) = dl(0) * dl(3)
                dl(11) = dl(1) * dl(2)
                dl(12) = dl(1) * dl(3)
                dl(13) = dl(2) * dl(3)
                for i in 0..14 {
                    st(i) = st(i) + g * dv(i)
                    for j in 0..14 {

                st(602 + k) = st(602 + k) + g * eo
                st(610 + k) = st(610 + k) + g * eo * eo
            ring(4 * slot) = xo
            ring(4 * slot + 1) = yo
            ring(4 * slot + 2) = pxo
            ring(4 * slot + 3) = pyo
        }
    }
    st
}


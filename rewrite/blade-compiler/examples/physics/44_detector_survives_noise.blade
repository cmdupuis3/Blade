let (Q0N, L0N) = m.eigh(C0N)
let QSN = method_for(range<Idx<14>>) <*> method_for(range<Idx<14>>) <@> lambda(i: Int64, k: Int64) -> Q0N(i, k) / sqrt(L0N(k)) |> compute

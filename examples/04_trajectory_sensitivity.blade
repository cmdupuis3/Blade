// TEST: Example Trajectory Units And Sensitivity
import ad as ad
// ============================================================================
// A projectile study in three parts, each using the language feature that
// actually fits:
//
//   A. Vacuum kinematics with UNIT-CHECKED scalars -- base units declared,
//      derived units (velocity, acceleration) flowing through * and / so a
//      dimensionally wrong formula cannot typecheck.
//   B. A DIFFERENTIABLE drag-loss estimate: energy lost to quadratic drag,
//      integrated by midpoint quadrature over the closed-form vacuum
//      velocity profile. The quadrature is a RECURSIVE ARRAY carrying the
//      running partial sum; grad() generates the reverse pass; the example
//      prints the AD sensitivities next to finite-difference quotients
//      computed in-file, and they must agree.
//      (AD discipline: the additive carry reads only the step ordinal and
//      the parameters, so the integrand is the closed form, not mutated
//      state -- exactly the prefix-sum shape grad() re-homes onto a
//      triangular scatter-add.)
//   C. The TRUE dynamics with drag, as a RECURSIVE ARRAY over time -- an
//      Euler recurrence whose each slice steps the whole packed state
//      vector once. Landing is handled by gating each update with an
//      airborne indicator (no break statement needed).
//
// EXPECT values verified against an independent PowerShell implementation
// of the same quadrature and simulation, plus the in-file FD self-checks.
// ============================================================================

// ============================================================================
// Part A -- unit-checked vacuum kinematics.
// ============================================================================
Unit meters
Unit seconds
Unit velocity = meters / seconds
Unit acceleration = meters / seconds^2

let vx0: Float<velocity> = 15.0
let vy0: Float<velocity> = 19.62
let grav: Float<acceleration> = 9.81

// velocity / acceleration = seconds; velocity * seconds = meters -- the
// checker tracks the dimensions through every step.
let t_apex = vy0 / grav
let t_flight = 2.0 * t_apex
let apex = 0.5 * vy0 * t_apex
let range_vac = vx0 * t_flight
// EXPECT: t_apex = 2.0
// EXPECT: t_flight = 4.0
// EXPECT: apex = 19.62
// EXPECT: range_vac = 60.0

// The same closed form, lifted to an ARRAY of sample instants. Units flow
// through the array operators exactly as through the scalar ones: the
// scalar-by-array broadcasts compose signatures elementwise (velocity *
// seconds = meters; acceleration * seconds = velocity, * seconds again =
// meters), the elementwise - requires both sides to agree, and the
// Float<meters> annotation on the result is CHECKED against the composed
// signature -- annotating it as, say, Float<seconds> would not compile.
type TIdx = Idx<3>
let ts: Array<Float<seconds> like TIdx> = [1.0, 2.0, 3.0]
let heights: Array<Float<meters> like TIdx> = vy0 * ts - 0.5 * grav * ts * ts
// h(t) = 19.62 t - 4.905 t^2: the t = 2.0 sample is the apex above.
// EXPECT: heights = [14.715, 19.62, 14.715]

// ============================================================================
// Part B -- differentiable drag-loss estimate.
// Power dissipated by quadratic drag is c_d |v|^3; integrating over the
// vacuum profile v(t) = (vx0, vy0 - g t) with N = 40 midpoint steps gives a
// first-order estimate of the energy lost per unit mass. The quadrature is a
// RECURSIVE ARRAY carrying the running partial sum: s(0) = 0, s(n) = s(n-1) +
// integrand(n-1), read at the final ordinal -- the additive-carry shape grad()
// differentiates (it re-expresses the prefix sum as a triangular scatter-add).
// The integrand is closed-form per step (built from the step ordinal and the
// parameters), so no state is mutated in the recurrence the reverse pass reads.
// ============================================================================
function drag_loss(ux: Float, uy: Float) -> Float = {
    let rec s: Array<Float like Idx<41>> =
        match s with
        | zero -> zero
        | zero :: n -> zero :: 0.0
        | prefix :: n -> prefix :: prefix(n - 1) + sqrt(ux * ux + (uy - 9.81 * ((1.0 * (n - 1) + 0.5) * (2.0 * uy / (9.81 * 40.0)))) * (uy - 9.81 * ((1.0 * (n - 1) + 0.5) * (2.0 * uy / (9.81 * 40.0))))) * (ux * ux + (uy - 9.81 * ((1.0 * (n - 1) + 0.5) * (2.0 * uy / (9.81 * 40.0)))) * (uy - 9.81 * ((1.0 * (n - 1) + 0.5) * (2.0 * uy / (9.81 * 40.0))))) * (2.0 * uy / (9.81 * 40.0))
    0.02 * s(40)
}

let (E_drag, dE_dvx0, dE_dvy0) = ad.grad(drag_loss)(15.0, 19.62)
// EXPECT: E_drag = 551.601893248218

// Finite-difference cross-checks, computed in this same file: the AD
// sensitivities and the central quotients must agree to ~1e-8.
let fd_vx = (drag_loss(15.00001, 19.62) - drag_loss(14.99999, 19.62)) / 0.00002
let fd_vy = (drag_loss(15.0, 19.62001) - drag_loss(15.0, 19.61999)) / 0.00002
// (the ~1e-8 daylight between the AD and FD numbers is the finite
// difference's own cancellation noise at h = 1e-5, not AD error)
// EXPECT: dE_dvx0 = 66.8109454543554
// EXPECT: fd_vx = 66.8109454636578
// EXPECT: dE_dvy0 = 61.3783583678664
// EXPECT: fd_vy = 61.3783583617078

// ============================================================================
// Part C -- the true dynamics, as a RECURSIVE ARRAY. Euler integration of the
// drag-coupled equations is a genuine recurrence (each velocity update reads
// the current velocity), so the state trajectory is a recursive array: the
// leading axis is time, each slice is the whole (x, y, vx, vy, ft) state
// vector stepped once from the prior slice. The airborne indicator gates every
// update, freezing the state at touchdown without control flow. The trajectory
// is block-local -- only the extracted landing quantities surface.
//
// The state is packed into one Float64 component vector (recursion needs a
// homogeneous element type), so the per-component unit checking of the scalar
// spelling is traded for the recursive form; the drag/gravity/dt constants are
// inlined as the literals declared below. The physics is unchanged: c_d * v *
// |v| is the quadratic-drag acceleration, sqrt carries speed from velocity^2,
// and dropping a * 0.01 from any update would change the trajectory, not slip
// past a checker.
// ============================================================================
Unit per_meter = meters^-1
let c_d: Float<per_meter> = 0.002
let dt: Float<seconds> = 0.01

// one Euler step of the packed state [x, y, vx, vy, ft]
function estep(prev: Array<Float64 like Idx<5>>) -> Array<Float64 like Idx<5>> =
    (method_for(range<Idx<5>>) <@> lambda(c: Int64) -> {
        let x = prev(0)
        let y = prev(1)
        let vx = prev(2)
        let vy = prev(3)
        let ft = prev(4)
        let airborne = if vy > 0.0 || y > 0.0 then 1.0 else 0.0
        let speed = sqrt(vx * vx + vy * vy)
        let ax = 0.0 - 0.002 * vx * speed
        let ay = 0.0 - 9.81 - 0.002 * vy * speed
        if c < 1 then x + airborne * vx * 0.01
        else if c < 2 then y + airborne * vy * 0.01
        else if c < 3 then vx + airborne * ax * 0.01
        else if c < 4 then vy + airborne * ay * 0.01
        else ft + airborne * 0.01
    }) |> compute

let sim: Float<meters> = {
    let rec traj: Array<Float64 like Idx<451>, Idx<5>> =
        match traj with
        | zero -> zero
        | zero :: s -> zero :: [0.0, 0.0, 15.0, 19.62, 0.0]
        | prefix :: n -> prefix :: estep(prefix(n - 1))
    let landing = traj(450)
    landing(0)
}
// Drag shortens the vacuum range (60 m) by about nine percent.
// EXPECT: sim = 54.7425173674639

let sim_time: Float<seconds> = {
    let rec traj: Array<Float64 like Idx<451>, Idx<5>> =
        match traj with
        | zero -> zero
        | zero :: s -> zero :: [0.0, 0.0, 15.0, 19.62, 0.0]
        | prefix :: n -> prefix :: estep(prefix(n - 1))
    let landing = traj(450)
    landing(4)
}
// ...and the flight time (4.0 s in vacuum) accordingly.
// EXPECT: sim_time = 3.90999999999996

// TEST: Physics -- The Dynamical q: Quantum Chaos Reshapes the Partition Lattice
// ============================================================================
// Ex 29's verdict on classical cascades was INHERITED_NOT_DYNAMICAL: all
// fifteen connected 4-cumulants were negative, but reweighting the input
// jets flipped every sign -- the dynamics TRANSPORTS the state's fourth
// cumulant, it cannot reshape the pairing lattice. Its header then claimed,
// untested: "dynamical crossing suppression is a genuinely quantum
// signature". This example tests that claim -- same estimator, same
// mirrored control -- on an exactly diagonalized quantum spin chain.
// Setup: mixed-field Ising chain, L = 6 (d = 64), open ends,
//   H = sum sz_i sz_{i+1} - 1.05 sum sx_i + sum h_i sz_i,
// irregular fields h = (0.55, 0.71, 0.44, 0.68, 0.50, 0.62) (chaotic; the
// irregularity kills reflection parity) vs the h = 0 twin (transverse-
// field Ising, free-fermion INTEGRABLE). H, A = sx on site 1, B = sz on
// site 6 are built IN-LANGUAGE from Int64 bit algebra; the eigenfactors
// (E, V) are EMBEDDED but CERTIFIED in-file (ex 41's move: residuals
// |HV - VE|^2 and |VV^T - I|^2 pinned at ~1e-18 -- the external solve's
// provenance is proof-irrelevant). Time evolution needs no matrix
// exponential: in the eigenbasis A(t) = X + iY with X_ij = A~_ij cos((E_i
// - E_j) t), Y_ij = A~_ij sin(...), and every trace below is real by
// symmetry (X, B~ symmetric, Y antisymmetric). The estimator is ex 29's
// crossing channel verbatim on the time-ordered quadruple (A(t), B, A(t),
// B): kappa4 = p - 2 cab^2 - cAA cBB, qhat = 1 + kappa4/(cAA cBB) -- the
// crossing pairing (13)(24) IS the out-of-time-order contraction, so qhat
// is the normalized OTOC. State = infinite temperature tr(.)/64, the
// quantum analogue of ex 29's uniform grid.
// FINDINGS (pinned):
//   * DYNAMICAL CROSSING SUPPRESSION EXISTS. qhat(0) = 1 exactly (A and B
//     commute at t = 0); under chaotic evolution it collapses to the
//     scrambling floor by t ~ 5 and STAYS: six incommensurate late times
//     (the comb, t in [20, 38.6]) have mean 0.0891, variance 1.5e-4.
//   * THE LIGHT CONE GATES IT. qhat(0.5) = 1 to twelve digits: the
//     suppression cannot switch on before the Lieb-Robinson front crosses
//     the five bonds from A to B (ex 26's causal cone, quantum side).
//   * THE MIRRORED CONTROL FAILS TO FLIP IT -- the point of the file.
//     Deform the state's shape exactly as ex 29 deformed the jets:
//     thermal weights e^{-0.3 E} and a spectrally leptokurtic reweight
//     w ~ 1 + 3((E - mean)/sd)^2, both computed in-language from the
//     certified spectrum. The floor moves (0.089 -> 0.080 / 0.172) but
//     every kappa4 stays NEGATIVE -- 12/12 sign checks across two states
//     x six comb times. In ex 29 the same move flipped 15/15. The
//     suppression belongs to the DYNAMICS: DYNAMICAL_NOT_INHERITED.
//   * INTEGRABILITY IS THE CONTROL'S CONTROL. The free-fermion twin at
//     the same six late times: mean 0.470, variance 0.146 -- 950x the
//     chaotic comb variance, swinging -0.17..+0.96. Unitarity alone does
//     not scramble the crossing channel; chaos does (ex 17's persistence
//     dichotomy, fourth-order edition).
//   * THE SPECTRUM AGREES, IN-LANGUAGE: bulk consecutive-gap ratio
//     r = 0.4731 (toward GOE 0.536) vs 0.2919 (below Poisson 0.386:
//     exact free-fermion degeneracies) -- chaos certified from the same
//     embedded eigenvalues the estimator runs on.
// With ex 29 the dichotomy is closed on both sides: classical mixing
// transports kurtosis and cannot suppress crossings; quantum chaos
// suppresses crossings and the state cannot restore them. Honest scope:
// freeness-from-ETH / OTOC decay is known physics; new here is the arc's
// own estimator + mirrored control + integrable twin, exact and pinned in
// one self-certifying file. Every number was verified against an
// independent complex-matmul route (agreement ~1e-14) before pinning.
// ============================================================================

// ---- certified eigenfactors (emitted by the untrusted oracle; certified below) ----
// CSV-backed since 2026-07-19: the eigenfactors live in data/42_*.csv
// (bit-identical extraction of the former inline literals). Run from THIS
// directory so the relative paths resolve: `cd examples/physics && blade
// run 42_dynamical_q.blade` — see providers/CsvProviderSpec.md. The 1-D
// payloads are stored as one CSV row; `(0)` peels the vector off the
// 1 x 64 load.
import csv as csvd
let EC_h = csvd.load("data/42_EC.csv")
let EC_m = EC_h.vars.data |> csvd.read
let EC: Array<Float64 like Idx<64>> = EC_m(0)
let VC_h = csvd.load("data/42_VC.csv")
let VC: Array<Float64 like Idx<64>, Idx<64>> = VC_h.vars.data |> csvd.read
let EI_h = csvd.load("data/42_EI.csv")
let EI_m = EI_h.vars.data |> csvd.read
let EI: Array<Float64 like Idx<64>> = EI_m(0)
let VI_h = csvd.load("data/42_VI.csv")
let VI: Array<Float64 like Idx<64>, Idx<64>> = VI_h.vars.data |> csvd.read
// ---- Int64 bit algebra (all quantities non-negative: the signed-promotion
//      hazard never arises; spins/indicators exit through if-else) ----
function eqInd(a: Int64, b: Int64) -> Float64 = if a + 1 > b then (if a < b + 1 then 1.0 else 0.0) else 0.0
function spn(i: Int64, p: Int64) -> Float64 = if (i / p) % 2 < 1 then 1.0 else 0.0 - 1.0
function xorbit(i: Int64, p: Int64) -> Int64 = i + p - 2 * p * ((i / p) % 2)

// ---- H, A, B in-language ----
let HC = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> eqInd(i, j) * (spn(i, 1) * spn(i, 2) + spn(i, 2) * spn(i, 4) + spn(i, 4) * spn(i, 8) + spn(i, 8) * spn(i, 16) + spn(i, 16) * spn(i, 32) + 0.55 * spn(i, 1) + 0.71 * spn(i, 2) + 0.44 * spn(i, 4) + 0.68 * spn(i, 8) + 0.50 * spn(i, 16) + 0.62 * spn(i, 32)) - 1.05 * (eqInd(j, xorbit(i, 1)) + eqInd(j, xorbit(i, 2)) + eqInd(j, xorbit(i, 4)) + eqInd(j, xorbit(i, 8)) + eqInd(j, xorbit(i, 16)) + eqInd(j, xorbit(i, 32))) |> compute
let HI = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> eqInd(i, j) * (spn(i, 1) * spn(i, 2) + spn(i, 2) * spn(i, 4) + spn(i, 4) * spn(i, 8) + spn(i, 8) * spn(i, 16) + spn(i, 16) * spn(i, 32)) - 1.05 * (eqInd(j, xorbit(i, 1)) + eqInd(j, xorbit(i, 2)) + eqInd(j, xorbit(i, 4)) + eqInd(j, xorbit(i, 8)) + eqInd(j, xorbit(i, 16)) + eqInd(j, xorbit(i, 32))) |> compute
let AX = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> eqInd(j, xorbit(i, 1)) |> compute
let BZ = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> eqInd(i, j) * spn(i, 32) |> compute

// ---- model C: certification + eigenbasis observables + gap statistics ----
let VTC = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> VC(j, i) |> compute
let HVC = method_for(HC, VTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let RSC = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> HVC(i, j) - VC(i, j) * EC(j) |> compute
let certC = reduce(method_for(zip(RSC, RSC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let GOC = method_for(VC, VC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let DOC = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> GOC(i, j) - eqInd(i, j) |> compute
let orthC = reduce(method_for(zip(DOC, DOC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let monoC = reduce(method_for(range<Idx<63>>) <@> lambda(k: Int64) -> (if EC(k + 1) < EC(k) then 1.0 else 0.0), (+))
let TAC = method_for(VTC, AX) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let ATC = method_for(TAC, VTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TBC = method_for(VTC, BZ) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let BTC = method_for(TBC, VTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let GPC = method_for(range<Idx<39>>) <@> lambda(k: Int64) -> EC(k + 13) - EC(k + 12) |> compute
let RQC = method_for(range<Idx<38>>) <@> lambda(k: Int64) -> (if GPC(k) < GPC(k + 1) then (if GPC(k + 1) < 0.000000000001 then 0.0 else GPC(k) / GPC(k + 1)) else (if GPC(k) < 0.000000000001 then 0.0 else GPC(k + 1) / GPC(k))) |> compute
let rstatC = reduce(method_for(RQC) <@> lambda(x) -> x, (+)) / 38.0

// ---- model I: certification + eigenbasis observables + gap statistics ----
let VTI = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> VI(j, i) |> compute
let HVI = method_for(HI, VTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let RSI = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> HVI(i, j) - VI(i, j) * EI(j) |> compute
let certI = reduce(method_for(zip(RSI, RSI)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let GOI = method_for(VI, VI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let DOI = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> GOI(i, j) - eqInd(i, j) |> compute
let orthI = reduce(method_for(zip(DOI, DOI)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let monoI = reduce(method_for(range<Idx<63>>) <@> lambda(k: Int64) -> (if EI(k + 1) < EI(k) then 1.0 else 0.0), (+))
let TAI = method_for(VTI, AX) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let ATI = method_for(TAI, VTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TBI = method_for(VTI, BZ) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let BTI = method_for(TBI, VTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let GPI = method_for(range<Idx<39>>) <@> lambda(k: Int64) -> EI(k + 13) - EI(k + 12) |> compute
let RQI = method_for(range<Idx<38>>) <@> lambda(k: Int64) -> (if GPI(k) < GPI(k + 1) then (if GPI(k + 1) < 0.000000000001 then 0.0 else GPI(k) / GPI(k + 1)) else (if GPI(k) < 0.000000000001 then 0.0 else GPI(k + 1) / GPI(k))) |> compute
let rstatI = reduce(method_for(RQI) <@> lambda(x) -> x, (+)) / 38.0

// ---- t = 0: the estimator opens at exactly 1 (commuting A, B) ----
let P0C = method_for(ATC, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let T0C = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> P0C(j, i) |> compute
let pa0C = reduce(method_for(zip(P0C, T0C)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cb0C = reduce(method_for(zip(ATC, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let q0C = pa0C / 64.0 - 2.0 * (cb0C / 64.0) * (cb0C / 64.0)
let P0I = method_for(ATI, BTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let T0I = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> P0I(j, i) |> compute
let pa0I = reduce(method_for(zip(P0I, T0I)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cb0I = reduce(method_for(zip(ATI, BTI)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let q0I = pa0I / 64.0 - 2.0 * (cb0I / 64.0) * (cb0I / 64.0)

// ---- chaotic sweep: light cone, arrival, collapse ----
let Xc05 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 0.5) |> compute
let Yc05 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 0.5) |> compute
let PXc05 = method_for(Xc05, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYc05 = method_for(Yc05, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXc05 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXc05(j, i) |> compute
let TYc05 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYc05(j, i) |> compute
let pac05 = reduce(method_for(zip(PXc05, TXc05)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbc05 = reduce(method_for(zip(PYc05, TYc05)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbc05 = reduce(method_for(zip(Xc05, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qc05 = (pac05 - pbc05) / 64.0 - 2.0 * (cbc05 / 64.0) * (cbc05 / 64.0)
let Xc1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 1.0) |> compute
let Yc1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 1.0) |> compute
let PXc1 = method_for(Xc1, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYc1 = method_for(Yc1, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXc1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXc1(j, i) |> compute
let TYc1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYc1(j, i) |> compute
let pac1 = reduce(method_for(zip(PXc1, TXc1)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbc1 = reduce(method_for(zip(PYc1, TYc1)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbc1 = reduce(method_for(zip(Xc1, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qc1 = (pac1 - pbc1) / 64.0 - 2.0 * (cbc1 / 64.0) * (cbc1 / 64.0)
let Xc2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 2.0) |> compute
let Yc2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 2.0) |> compute
let PXc2 = method_for(Xc2, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYc2 = method_for(Yc2, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXc2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXc2(j, i) |> compute
let TYc2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYc2(j, i) |> compute
let pac2 = reduce(method_for(zip(PXc2, TXc2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbc2 = reduce(method_for(zip(PYc2, TYc2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbc2 = reduce(method_for(zip(Xc2, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qc2 = (pac2 - pbc2) / 64.0 - 2.0 * (cbc2 / 64.0) * (cbc2 / 64.0)
let Xc3 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 3.0) |> compute
let Yc3 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 3.0) |> compute
let PXc3 = method_for(Xc3, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYc3 = method_for(Yc3, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXc3 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXc3(j, i) |> compute
let TYc3 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYc3(j, i) |> compute
let pac3 = reduce(method_for(zip(PXc3, TXc3)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbc3 = reduce(method_for(zip(PYc3, TYc3)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbc3 = reduce(method_for(zip(Xc3, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qc3 = (pac3 - pbc3) / 64.0 - 2.0 * (cbc3 / 64.0) * (cbc3 / 64.0)
let Xc5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 5.0) |> compute
let Yc5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 5.0) |> compute
let PXc5 = method_for(Xc5, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYc5 = method_for(Yc5, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXc5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXc5(j, i) |> compute
let TYc5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYc5(j, i) |> compute
let pac5 = reduce(method_for(zip(PXc5, TXc5)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbc5 = reduce(method_for(zip(PYc5, TYc5)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbc5 = reduce(method_for(zip(Xc5, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qc5 = (pac5 - pbc5) / 64.0 - 2.0 * (cbc5 / 64.0) * (cbc5 / 64.0)

// ---- chaotic late-time comb (six incommensurate times) ----
let Xk1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 20.0) |> compute
let Yk1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 20.0) |> compute
let PXk1 = method_for(Xk1, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYk1 = method_for(Yk1, BTC) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXk1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXk1(j, i) |> compute
let TYk1 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYk1(j, i) |> compute
let pak1 = reduce(method_for(zip(PXk1, TXk1)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbk1 = reduce(method_for(zip(PYk1, TYk1)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbk1 = reduce(method_for(zip(Xk1, BTC)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qk1 = (pak1 - pbk1) / 64.0 - 2.0 * (cbk1 / 64.0) * (cbk1 / 64.0)
let Xk2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 23.7) |> compute

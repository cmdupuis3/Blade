let qm4 = (pam4 - pbm4) / 64.0 - 2.0 * (cbm4 / 64.0) * (cbm4 / 64.0)
let Xm5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATI(i, j) * cos((EI(i) - EI(j)) * 35.1) |> compute
let Ym5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATI(i, j) * sin((EI(i) - EI(j)) * 35.1) |> compute
let PXm5 = method_for(Xm5, BTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYm5 = method_for(Ym5, BTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXm5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXm5(j, i) |> compute
let TYm5 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYm5(j, i) |> compute
let pam5 = reduce(method_for(zip(PXm5, TXm5)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbm5 = reduce(method_for(zip(PYm5, TYm5)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbm5 = reduce(method_for(zip(Xm5, BTI)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qm5 = (pam5 - pbm5) / 64.0 - 2.0 * (cbm5 / 64.0) * (cbm5 / 64.0)
let Xm6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATI(i, j) * cos((EI(i) - EI(j)) * 38.6) |> compute
let Ym6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATI(i, j) * sin((EI(i) - EI(j)) * 38.6) |> compute
let PXm6 = method_for(Xm6, BTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PYm6 = method_for(Ym6, BTI) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let TXm6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PXm6(j, i) |> compute
let TYm6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> PYm6(j, i) |> compute
let pam6 = reduce(method_for(zip(PXm6, TXm6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let pbm6 = reduce(method_for(zip(PYm6, TYm6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cbm6 = reduce(method_for(zip(Xm6, BTI)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let qm6 = (pam6 - pbm6) / 64.0 - 2.0 * (cbm6 / 64.0) * (cbm6 / 64.0)

// ---- comb statistics: floor + equilibration vs ringing ----
let meanK = (qk1 + qk2 + qk3 + qk4 + qk5 + qk6) / 6.0
let varK = ((qk1 - meanK) * (qk1 - meanK) + (qk2 - meanK) * (qk2 - meanK) + (qk3 - meanK) * (qk3 - meanK) + (qk4 - meanK) * (qk4 - meanK) + (qk5 - meanK) * (qk5 - meanK) + (qk6 - meanK) * (qk6 - meanK)) / 6.0
let meanM = (qm1 + qm2 + qm3 + qm4 + qm5 + qm6) / 6.0
let varM = ((qm1 - meanM) * (qm1 - meanM) + (qm2 - meanM) * (qm2 - meanM) + (qm3 - meanM) * (qm3 - meanM) + (qm4 - meanM) * (qm4 - meanM) + (qm5 - meanM) * (qm5 - meanM) + (qm6 - meanM) * (qm6 - meanM)) / 6.0

// ---- THE MIRRORED CONTROL: deform the state's shape (ex 29's reweighting
//      move), weights computed in-language from the certified spectrum ----
let WT0 = method_for(EC) <@> lambda(x) -> exp(0.0 - 0.3 * x) |> compute
let zTH = reduce(method_for(WT0) <@> lambda(x) -> x, (+))
let WTH = method_for(WT0) <@> lambda(x) -> x / zTH |> compute
let eMean = reduce(method_for(EC) <@> lambda(x) -> x, (+)) / 64.0
let eVar = reduce(method_for(EC) <@> lambda(x) -> (x - eMean) * (x - eMean), (+)) / 64.0
let WL0 = method_for(EC) <@> lambda(x) -> 1.0 + 3.0 * (x - eMean) * (x - eMean) / eVar |> compute
let zLP = reduce(method_for(WL0) <@> lambda(x) -> x, (+))
let WLP = method_for(WL0) <@> lambda(x) -> x / zLP |> compute

let aMT = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WTH(k) * ATC(k, k), (+))
let bMT = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WTH(k) * BTC(k, k), (+))
let BCT = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> BTC(i, j) - bMT * eqInd(i, j) |> compute
let WBT = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * BCT(i, j) |> compute
let cBBT = reduce(method_for(zip(WBT, BCT)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let aML = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WLP(k) * ATC(k, k), (+))
let bML = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WLP(k) * BTC(k, k), (+))
let BCL = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> BTC(i, j) - bML * eqInd(i, j) |> compute
let WBL = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * BCL(i, j) |> compute
let cBBL = reduce(method_for(zip(WBL, BCL)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))

let XCt2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 23.7) - aMT * eqInd(i, j) |> compute
let YCt2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 23.7) |> compute
let WXt2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * XCt2(i, j) |> compute
let WYt2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * YCt2(i, j) |> compute
let PCt2 = method_for(XCt2, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDt2 = method_for(BCT, XCt2) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPt2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * PCt2(i, j) |> compute
let P2t2 = method_for(YCt2, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let P2Tt2 = method_for(BCT, YCt2) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let W2t2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * P2t2(i, j) |> compute
let ca1t2 = reduce(method_for(zip(WXt2, XCt2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2t2 = reduce(method_for(zip(WYt2, YCt2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAt2 = ca1t2 + ca2t2
let p1t2 = reduce(method_for(zip(WPt2, PDt2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2t2 = reduce(method_for(zip(W2t2, P2Tt2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cabt2 = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WTH(k) * PCt2(k, k), (+))
let kapt2 = (p1t2 - p2t2) - 2.0 * cabt2 * cabt2 - cAAt2 * cBBT
let qt2 = 1.0 + kapt2 / (cAAt2 * cBBT)
let XCt4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 31.3) - aMT * eqInd(i, j) |> compute
let YCt4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 31.3) |> compute
let WXt4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * XCt4(i, j) |> compute
let WYt4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * YCt4(i, j) |> compute
let PCt4 = method_for(XCt4, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDt4 = method_for(BCT, XCt4) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPt4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * PCt4(i, j) |> compute
let P2t4 = method_for(YCt4, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let P2Tt4 = method_for(BCT, YCt4) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let W2t4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * P2t4(i, j) |> compute
let ca1t4 = reduce(method_for(zip(WXt4, XCt4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2t4 = reduce(method_for(zip(WYt4, YCt4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAt4 = ca1t4 + ca2t4
let p1t4 = reduce(method_for(zip(WPt4, PDt4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2t4 = reduce(method_for(zip(W2t4, P2Tt4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cabt4 = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WTH(k) * PCt4(k, k), (+))
let kapt4 = (p1t4 - p2t4) - 2.0 * cabt4 * cabt4 - cAAt4 * cBBT
let qt4 = 1.0 + kapt4 / (cAAt4 * cBBT)
let XCt6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 38.6) - aMT * eqInd(i, j) |> compute
let YCt6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 38.6) |> compute
let WXt6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * XCt6(i, j) |> compute
let WYt6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * YCt6(i, j) |> compute
let PCt6 = method_for(XCt6, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDt6 = method_for(BCT, XCt6) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPt6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * PCt6(i, j) |> compute
let P2t6 = method_for(YCt6, BCT) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let P2Tt6 = method_for(BCT, YCt6) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let W2t6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WTH(i) * P2t6(i, j) |> compute
let ca1t6 = reduce(method_for(zip(WXt6, XCt6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2t6 = reduce(method_for(zip(WYt6, YCt6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAt6 = ca1t6 + ca2t6
let p1t6 = reduce(method_for(zip(WPt6, PDt6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2t6 = reduce(method_for(zip(W2t6, P2Tt6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cabt6 = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WTH(k) * PCt6(k, k), (+))
let kapt6 = (p1t6 - p2t6) - 2.0 * cabt6 * cabt6 - cAAt6 * cBBT
let qt6 = 1.0 + kapt6 / (cAAt6 * cBBT)
let XCl2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 23.7) - aML * eqInd(i, j) |> compute
let YCl2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 23.7) |> compute
let WXl2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * XCl2(i, j) |> compute
let WYl2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * YCl2(i, j) |> compute
let PCl2 = method_for(XCl2, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDl2 = method_for(BCL, XCl2) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPl2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * PCl2(i, j) |> compute
let P2l2 = method_for(YCl2, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let P2Tl2 = method_for(BCL, YCl2) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let W2l2 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * P2l2(i, j) |> compute
let ca1l2 = reduce(method_for(zip(WXl2, XCl2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2l2 = reduce(method_for(zip(WYl2, YCl2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAl2 = ca1l2 + ca2l2
let p1l2 = reduce(method_for(zip(WPl2, PDl2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2l2 = reduce(method_for(zip(W2l2, P2Tl2)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cabl2 = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WLP(k) * PCl2(k, k), (+))
let kapl2 = (p1l2 - p2l2) - 2.0 * cabl2 * cabl2 - cAAl2 * cBBL
let ql2 = 1.0 + kapl2 / (cAAl2 * cBBL)
let XCl4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 31.3) - aML * eqInd(i, j) |> compute

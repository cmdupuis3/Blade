let XCl6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * cos((EC(i) - EC(j)) * 38.6) - aML * eqInd(i, j) |> compute
let YCl6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> ATC(i, j) * sin((EC(i) - EC(j)) * 38.6) |> compute
let WXl6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * XCl6(i, j) |> compute
let WYl6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * YCl6(i, j) |> compute
let PCl6 = method_for(XCl6, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDl6 = method_for(BCL, XCl6) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPl6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * PCl6(i, j) |> compute
let P2l6 = method_for(YCl6, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let P2Tl6 = method_for(BCL, YCl6) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let W2l6 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * P2l6(i, j) |> compute
let ca1l6 = reduce(method_for(zip(WXl6, XCl6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2l6 = reduce(method_for(zip(WYl6, YCl6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAl6 = ca1l6 + ca2l6
let p1l6 = reduce(method_for(zip(WPl6, PDl6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2l6 = reduce(method_for(zip(W2l6, P2Tl6)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cabl6 = reduce(method_for(range<Idx<64>>) <@> lambda(k: Int64) -> WLP(k) * PCl6(k, k), (+))
let kapl6 = (p1l6 - p2l6) - 2.0 * cabl6 * cabl6 - cAAl6 * cBBL
let ql6 = 1.0 + kapl6 / (cAAl6 * cBBL)

let meanTH = (qt2 + qt4 + qt6) / 3.0
let meanLP = (ql2 + ql4 + ql6) / 3.0

// ---- verdicts ----
let certV = if certC < 0.0000000000000001 then (if orthC < 0.0000000000000001 then (if certI < 0.0000000000000001 then (if orthI < 0.0000000000000001 then (if monoC < 0.5 then (if monoI < 0.5 then "EIGENFACTORS_CERTIFIED" else "NO") else "NO") else "NO") else "NO") else "NO") else "NO"
let rstatV = if rstatC > 0.44 then (if rstatI < 0.35 then "GOE_VS_DEGENERATE_POISSON" else "NO") else "NO"
let openV = if sqrt((q0C - 1.0) * (q0C - 1.0)) < 0.000000001 then (if sqrt((q0I - 1.0) * (q0I - 1.0)) < 0.000000001 then "OPENS_AT_WICK" else "NO") else "NO"
let coneV = if sqrt((qc05 - 1.0) * (qc05 - 1.0)) < 0.000000001 then "SUPPRESSION_WAITS_FOR_THE_FRONT" else "NO"
let floorV = if varK < 0.01 then (if meanK < 0.15 then "FLOOR_EQUILIBRATED" else "NO") else "NO"
let ringV = if varM > 0.01 then "INTEGRABLE_STILL_RINGING" else "NO"
// kappa4 sign census across the deformed states (the ex-29 flip test):
// at infinite temperature kappa4 = qhat - 1 (unit normalizer)
let nnegK = (if qk1 < 1.0 then 1.0 else 0.0) + (if qk2 < 1.0 then 1.0 else 0.0) + (if qk3 < 1.0 then 1.0 else 0.0) + (if qk4 < 1.0 then 1.0 else 0.0) + (if qk5 < 1.0 then 1.0 else 0.0) + (if qk6 < 1.0 then 1.0 else 0.0)
let nnegW = (if kapt2 < 0.0 then 1.0 else 0.0) + (if kapt4 < 0.0 then 1.0 else 0.0) + (if kapt6 < 0.0 then 1.0 else 0.0) + (if kapl2 < 0.0 then 1.0 else 0.0) + (if kapl4 < 0.0 then 1.0 else 0.0) + (if kapl6 < 0.0 then 1.0 else 0.0)
let robustV = if nnegK > 5.5 then (if nnegW > 5.5 then "K4_SIGN_ROBUST" else "PARTIAL_FLIP") else "PARTIAL_FLIP"
let verdictV = if nnegW > 5.5 then (if varK < 0.01 then "DYNAMICAL_NOT_INHERITED" else "NO") else "INHERITED"


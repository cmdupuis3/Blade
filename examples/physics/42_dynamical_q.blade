let W2l4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * P2l4(i, j) |> compute
let ca1l4 = reduce(method_for(zip(WXl4, XCl4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let ca2l4 = reduce(method_for(zip(WYl4, YCl4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let cAAl4 = ca1l4 + ca2l4
let p1l4 = reduce(method_for(zip(WPl4, PDl4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))
let p2l4 = reduce(method_for(zip(W2l4, P2Tl4)) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y), (+))

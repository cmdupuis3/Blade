let WXl4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * XCl4(i, j) |> compute
let WYl4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * YCl4(i, j) |> compute
let PCl4 = method_for(XCl4, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let PDl4 = method_for(BCL, XCl4) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute
let WPl4 = method_for(range<Idx<64>>) <*> method_for(range<Idx<64>>) <@> lambda(i: Int64, j: Int64) -> WLP(i) * PCl4(i, j) |> compute
let P2l4 = method_for(YCl4, BCL) <@> lambda(x: Array<Float64 like Idx<64>>, y: Array<Float64 like Idx<64>>) -> prodsum(x, y) |> compute

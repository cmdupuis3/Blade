# ---- Blade compiler output ----
# The C++ the compiler emits, plus the compile+run scratch the test harness
# creates beside the binary.
generated_cpp_tests/

# The compiler deploys its C++ runtime headers next to every generated .cpp,
# and `blade build` with no -o writes them into the current directory -- which
# is how copies end up beside the corpus sources. src/cpp/ is canonical; these
# trees hold only .blade programs and data.
/tests/corpus/**/*.h
/tests/corpus/**/*.hpp
/tests/corpus/**/*.cpp
/examples/**/*.h
/examples/**/*.hpp
/examples/**/*.cpp
*.obj
*.ilk
*.pdb
*.exp
*.lib

